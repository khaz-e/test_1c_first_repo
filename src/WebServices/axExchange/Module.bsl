// Загрузка статуса заказа документа
//
// 2022.03.24 1c_dev2
// В эту процедуру попадаю только Ожидаемые приемки
Функция _SetDocumentStatus(Object, NodeID, Status) Экспорт
		
	Попытка
		
		Если Object.DocumentType = "Приемка от поставщика" Тогда
			
			ИмяДокумента 		= "ЗаказПоставщику";
			ИмяРеквизитаСклад 	= "Склад";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.ПриходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Приемка со склада" Тогда
			
			ИмяДокумента 		= "ПеремещениеТоваров";
			ИмяРеквизитаСклад 	= "СкладПолучатель";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.ПриходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Возврат от клиента" Тогда
			
			ИмяДокумента 		= "ВозвратТоваровОтПокупателя";
			ИмяРеквизитаСклад 	= "СкладОрдер";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.ПриходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Оприходование товаров" Тогда
			
			ИмяДокумента 		= "ОприходованиеТоваров";
			ИмяРеквизитаСклад 	= "Склад";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.ПриходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Отгрузка клиенту" Тогда
			
			ИмяДокумента 		= "РеализацияТоваровУслуг";
			ИмяРеквизитаСклад 	= "Склад";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.РасходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Самовывоз" Тогда
			
			ИмяДокумента 		= "РеализацияТоваровУслуг";
			ИмяРеквизитаСклад 	= "Склад";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.РасходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Отгрузка на склад" Тогда
			
			ИмяДокумента 		= "ПеремещениеТоваров";
			ИмяРеквизитаСклад 	= "СкладОтправитель";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.РасходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "Списание" Тогда
			
			ИмяДокумента 		= "СписаниеТоваров";
			ИмяРеквизитаСклад 	= "Склад";
			ВидОперации 		= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.РасходныйОрдер;
			
		ИначеЕсли Object.DocumentType = "КорректировкаРеализации" Тогда
			
			Возврат Истина;
			
		Иначе
			
			Возврат Истина;
			
		КонецЕсли;
		
		НачатьТранзакцию();
			
		ДокументОснование 		= Документы[ИмяДокумента].ПолучитьСсылку(Новый УникальныйИдентификатор(Object.ID));
		СтатусДокументаИзWMS 	= СопоставитьСтатусWMS4_ОжидаемаяПриемка(Object.Status);
		
		// 2022.03.23 1c_dev2 [start]
		// ДатаРазгрузки (DateUnload) в Ожидаемой приемке ставится до приемки и размещения (при статусе К выполнению)
		// Она является фактом прихода груза на склад
		// Ставим статус "Разгружен", если в Object  Status = "К выполнению", иначе информация о том, что товар разгружен не актуальна,
		// т.к он либо уже принят, либо размещен
		Если  ИмяДокумента = "ЗаказПоставщику" И Object.Status = "К выполнению" И ЗначениеЗаполнено(Object.DateUnload) Тогда
		      СтатусДокументаИзWMS = Перечисления.усСтатусыДокументов.Разгружен
		КонецЕсли;
		// 2022.03.23 1c_dev2 [end]
		
		Запрос = Новый Запрос();
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ax_СкладскойОрдер.Ссылка КАК ДокументСсылка
		|ИЗ
		|	Документ.ax_СкладскойОрдер КАК ТДФ_WMS_СкладскойОрдер
		|ГДЕ
		|	ax_СкладскойОрдер.ДокументОснование = &ДокументОснование
		|	И ax_СкладскойОрдер.ВидОперации = &ВидОперации
		|	И ax_СкладскойОрдер.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("ДокументОснование"	, ДокументОснование);
		Запрос.УстановитьПараметр("ВидОперации"			, ВидОперации);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ДокументОбъект = Выборка.ДокументСсылка.ПолучитьОбъект();
			ДокументОбъект.усСтатусДокумента 	= СтатусДокументаИзWMS; // 2022.03.23 1c_dev2
			ДокументОбъект.КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
		Иначе
			ДокументОбъект 						= Документы.ax_СкладскойОрдер.СоздатьДокумент();
			ДокументОбъект.ВидОперации 			= ВидОперации;
			ДокументОбъект.Склад 				= ДокументОснование[ИмяРеквизитаСклад];
			ДокументОбъект.ДокументОснование 	= ДокументОснование;
			ДокументОбъект.усСтатусДокумента 	= СтатусДокументаИзWMS;
			ДокументОбъект.КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
			ДокументОбъект.Дата 				= Object.Date;
			ДокументОбъект.Номер 				= Object.Number;
		КонецЕсли;	
		
		ДокументОбъект.ОбменДанными.Загрузка = Истина;
		
		// 2022.04.27 1c_dev2 [start]
		// Закомментируем попытку-исключение, т.к. транзакция фиксируется даже при исключении 
		// и объект удаляется из плана обмена WMS
		//Попытка
		ДокументОбъект.Записать();
		//Исключение
		//	ЗаписьЖурналаРегистрации("WMS_СтатусДокумента", УровеньЖурналаРегистрации.Ошибка, , , "Ошибка при установке статуса: " + СокрЛП(Object.ID) + ", " + СокрЛП(ОписаниеОшибки()));
		//КонецПопытки;
		// 2022.04.27 1c_dev2 [end]
			
		ЗафиксироватьТранзакцию();
		Возврат Истина;
		
	Исключение
		
		ОтменитьТранзакцию();
		//ОписаниеОшибки = ОписаниеОшибки();
		// 2022.04.27 1c_dev2 К комментарию записи журнала добавлен Object.ID 
		//ЗаписьЖурналаРегистрации("axExchange", УровеньЖурналаРегистрации.Ошибка, , ,"SetDocumentStatus(): " + СокрЛП(Object.ID) + ", " + ОписаниеОшибки);
		//ЗаписатьВЖурналРегистрации("SetDocumentStatus()", Object.ID, ОписаниеОшибки());
		Возврат Ложь;
		
	КонецПопытки;
	
КонецФункции

