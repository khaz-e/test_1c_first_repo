#Область ОбменСWMS 

// Установка статусов приходных ордеров
// Создает или находит приходный ордер  
// если он не отменен в WMS то устанавливает статус приходного ордера
// 		дополнительно если массив ТоварыПоступлениявWMS не пустой 
//			то перезаписывается табличная часть приходного ордера Товары
// если он отменен в WMS то найденный приходный ордер распроводится и помечается на удаление
//
// ПриходныйОрдерНаТовары.Отправитель ОпределяемыйТип.ОтправительПолучательТоваров
// 		ОпределяемыйТип.ОтправительПолучательТоваров
//			СправочникСсылка.СтруктураПредприятия, 
//			СправочникСсылка.Партнеры, 
//			СправочникСсылка.ФизическиеЛица, 
//			СправочникСсылка.Склады
Функция SetDocumentStatus(Object, NodeID, Status)
	
	СозданиеОрдераСтруктура = ax_СинхронизацияПриемкиОтгрузкиТоваров
		.НовыйСозданиеОрдераСтруктура();
				
	ax_СинхронизацияПриемкиОтгрузкиТоваров
		.ОбъектXDTOВСозданиеОрдераПоступлениеСтруктура(Object, СозданиеОрдераСтруктура);	
		
	Если СозданиеОрдераСтруктура.Ошибка Тогда
		
		ОбменДаннымиWMS4.ЗаписатьВЖурналРегистрации(
			СтрШаблон( "SetDocumentStatus():
				|%1", СозданиеОрдераСтруктура.ТекстСообщения));
		
	ИначеЕсли НЕ СозданиеОрдераСтруктура.ДокументОснованияПроведен Тогда 
		СозданиеОрдераСтруктура.Результат = Истина;
	Иначе 	
		ax_СинхронизацияПриемкиОтгрузкиТоваров
			.УстановитьФактПриемки(СозданиеОрдераСтруктура, Status);
	КонецЕсли;
	
	// не критические ошибки
	Если НЕ СозданиеОрдераСтруктура.Ошибка 
		И НЕ ПустаяСтрока(СозданиеОрдераСтруктура.ТекстСообщения)  Тогда 
		
		ТекстСообщения = СтрШаблон("SetDocumentStatus():
			|%1", СозданиеОрдераСтруктура.ТекстСообщения);
				
		ОбменДаннымиWMS4.ЗаписатьВЖурналРегистрации(
			ТекстСообщения, 
			"Предупреждение",
			СозданиеОрдераСтруктура.ДокументОснования.Метаданные(), 
			СозданиеОрдераСтруктура.ДокументОснования);
			
	КонецЕсли;	
	
	Возврат СозданиеОрдераСтруктура.Результат;
	
КонецФункции

// Загрузка ПриходныйОрдерНаТовары
//
Функция SetArrivalFact(Object, NodeID)
	
	СозданиеОрдераСтруктура = ax_СинхронизацияПриемкиОтгрузкиТоваров
		.НовыйСозданиеОрдераСтруктура();

	ax_СинхронизацияПриемкиОтгрузкиТоваров
		.ОбъектXDTOВСозданиеОрдераПоступлениеСтруктура(Object, СозданиеОрдераСтруктура);
	
	Если СозданиеОрдераСтруктура.Ошибка Тогда
		
		ОбменДаннымиWMS4.ЗаписатьВЖурналРегистрации(
			СтрШаблон( "SetArrivalFact():
				|%1", СозданиеОрдераСтруктура.ТекстСообщения));
		
	ИначеЕсли НЕ СозданиеОрдераСтруктура.ДокументОснованияПроведен Тогда 
		СозданиеОрдераСтруктура.Результат = Истина;
	Иначе 	
		ax_СинхронизацияПриемкиОтгрузкиТоваров
			.УстановитьФактПриемки(СозданиеОрдераСтруктура);
	КонецЕсли;
	
	// не критические ошибки
	Если НЕ СозданиеОрдераСтруктура.Ошибка 
		И НЕ ПустаяСтрока(СозданиеОрдераСтруктура.ТекстСообщения) Тогда 
		
		ТекстСообщения = СтрШаблон("SetArrivalFact():
			|%1", СозданиеОрдераСтруктура.ТекстСообщения);
				
		ОбменДаннымиWMS4.ЗаписатьВЖурналРегистрации(
			ТекстСообщения,
			"Предупреждение",
			СозданиеОрдераСтруктура.ДокументОснования.Метаданные(), 
			СозданиеОрдераСтруктура.ДокументОснования);
			
	КонецЕсли;	
	
	Возврат СозданиеОрдераСтруктура.Результат;
  
КонецФункции

// Загрузка РасходныйОрдерНаТовары
//
Функция SetShipmentFact(Object, NodeID)
	
	СозданиеОрдераСтруктура = ax_СинхронизацияПриемкиОтгрузкиТоваров
		.НовыйСозданиеОрдераСтруктура();
		
	ax_СинхронизацияПриемкиОтгрузкиТоваров
		.ОбъектXDTOВСозданиеОрдераОтгрузкаСтруктура(
			Object, СозданиеОрдераСтруктура);	
		
	Если СозданиеОрдераСтруктура.Ошибка Тогда
		
		ОбменДаннымиWMS4.ЗаписатьВЖурналРегистрации(
			СтрШаблон( "SetFactShipment():
			|%1", СозданиеОрдераСтруктура.ТекстСообщения));
		
	ИначеЕсли НЕ СозданиеОрдераСтруктура.ДокументОснованияПроведен Тогда 
		СозданиеОрдераСтруктура.Результат = Истина;
	Иначе 	
		ax_СинхронизацияПриемкиОтгрузкиТоваров
			.УстановитьФактОтгрузки(СозданиеОрдераСтруктура);
	КонецЕсли;
	
	// не критические ошибки
	Если НЕ СозданиеОрдераСтруктура.Ошибка 
		И НЕ ПустаяСтрока(СозданиеОрдераСтруктура.ТекстСообщения) Тогда 
		
		ТекстСообщения = СтрШаблон("SetFactShipment():
			|%1", СозданиеОрдераСтруктура.ТекстСообщения);
		
		ОбменДаннымиWMS4.ЗаписатьВЖурналРегистрации(
			ТекстСообщения, 
			"Предупреждение",
			СозданиеОрдераСтруктура.ДокументОснования.Метаданные(), 
			СозданиеОрдераСтруктура.ДокументОснования);

	КонецЕсли;
		
	Возврат СозданиеОрдераСтруктура.Результат;
	
КонецФункции

Функция GetRemains(NodeID)
	ТаблицаНастройкиУзлов = ПланыОбмена.ОбменУправлениеТорговлейWMS4.ПолучитьНастройкиУзлов();	
	ЗначениеИзСтрокиXML = ОбщегоНазначения.ЗначениеИзСтрокиXML(NodeID);	
	СтруктураОтвет = Новый Структура("ТаблицаОстаткиУТ, Результат, ТекстСообщения", Неопределено, Ложь, "");
	ТекстСообщения = "";
	
	СтрокиТаблицыНастройкиУзлов = ТаблицаНастройкиУзлов
		.НайтиСтроки (Новый Структура("Идентификатор", ЗначениеИзСтрокиXML.ИдентификаторУзла));
		
	Если СтрокиТаблицыНастройкиУзлов.Количество() = 0 Тогда 
		ТекстСообщения = СтрШаблон("%1
			|Не удалось найти  узел обмена в базе по идентификатору узла: %2", 
			ТекстСообщения, ЗначениеИзСтрокиXML.ИдентификаторУзла);	
	КонецЕсли;
	
	Если ЗначениеИзСтрокиXML.МассивУИДы.Количество() = 0 Тогда 
		ТекстСообщения = СтрШаблон("%1
			|Пустой список  УИДов номенклатуры по идентификатору узла: %2", 
			ТекстСообщения, ЗначениеИзСтрокиXML.ИдентификаторУзла);		
	КонецЕсли;
	
	Склады = Новый Массив;
	Для Каждого СтрокаТаблицыНастройкиУзлов Из СтрокиТаблицыНастройкиУзлов Цикл 
		Склады.Добавить(СтрокаТаблицыНастройкиУзлов.Склад);
	КонецЦикла;
		
	СписокНоменклатуры = Новый Массив;
	Для Каждого УИД Из ЗначениеИзСтрокиXML.МассивУИДы Цикл
		НоменклатураСсылка = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(УИД));
		
		Если Найти(Строка(НоменклатураСсылка), "<Объект не найден>") <> 0 Тогда
			ТекстСообщения = СтрШаблон("%1
				|Не удалось найти номенклатуру в базе по УИД: %2", ТекстСообщения, УИД);
		Иначе 
			СписокНоменклатуры.Добавить(НоменклатураСсылка);	
		КонецЕсли;
	КонецЦикла;
	
	Если Склады.Количество() > 0 И СписокНоменклатуры.Количество() > 0 Тогда 
		СтруктураРезультатЗапроса = ОбменДаннымиWMS4
			.ОстаткиНоменклатурыНаСкладах(СписокНоменклатуры, Склады);
			
		Если НЕ СтруктураРезультатЗапроса.Ошибка	Тогда 
			СтруктураОтвет.ТаблицаОстаткиУТ = СтруктураРезультатЗапроса.РезультатЗапроса.Выгрузить();
			СтруктураОтвет.Результат = Истина;	
		Иначе 
			СтруктураОтвет.ТекстСообщения = СтруктураРезультатЗапроса.ОписаниеОшибки;	
		КонецЕсли;
	КонецЕсли;
	
	СтруктураОтвет.ТекстСообщения = СокрЛП(ТекстСообщения);
	
	СтрокаXML = ОбщегоНазначения.ЗначениеВСтрокуXML(СтруктураОтвет);
	
	Возврат СтрокаXML;
КонецФункции

#Область ОбменСWMS_старый 

// Загрузка Отражения факта приемки
//
// 2022.03.24 1c_dev2
// В эту процедуру попадаю только Приемки
Функция _SetArrivalFact(Object, NodeID)
	
	Попытка
		
		Если Object.DocumentType = "Оприходование товаров" Тогда
			ИмяДокумента = "ОприходованиеТоваров";
			ИмяРеквизитаСклад = "Склад";
		ИначеЕсли Object.DocumentType = "Возврат от клиента" Тогда
			ИмяДокумента = "ВозвратТоваровОтПокупателя";
			ИмяРеквизитаСклад = "СкладОрдер";
		ИначеЕсли Object.DocumentType = "Приемка от поставщика" Тогда
			ИмяДокумента = "ЗаказПоставщику";
			ИмяРеквизитаСклад = "Склад";
		ИначеЕсли Object.DocumentType = "Приемка со склада" Тогда
			ИмяДокумента = "ПеремещениеТоваров";
			ИмяРеквизитаСклад = "СкладОтправитель";
		ИначеЕсли Object.DocumentType = "Корректировка реализации" Тогда
			ИмяДокумента = "КорректировкаРеализации";
			ИмяРеквизитаСклад = "Склад";
		ИначеЕсли Object.DocumentType = "Приемка из производства" Тогда
			ИмяДокумента = "КомплектацияНоменклатуры";
			ИмяРеквизитаСклад = "Склад";
		Иначе
			Возврат Истина;
		КонецЕсли;	
		
		НачатьТранзакцию();
		
		ДокументОснование 		= Документы[ИмяДокумента].ПолучитьСсылку(Новый УникальныйИдентификатор(Object.ID));
		СтатусДокументаИзWMS 	= СопоставитьСтатусWMS4_ОжидаемаяПриемка(Object.Status);
		
		Запрос = Новый Запрос();
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ax_СкладскойОрдер.Ссылка КАК ДокументСсылка
		|ИЗ
		|	Документ.ax_СкладскойОрдер КАК ax_СкладскойОрдер
		|ГДЕ
		|	ax_СкладскойОрдер.ДокументОснование = &ДокументОснование
		|	И ax_СкладскойОрдер.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ТДФ_ВидОперацииСкладскойОрдерWMS.ПриходныйОрдер)
		|	И ax_СкладскойОрдер.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ДокументОбъект = Выборка.ДокументСсылка.ПолучитьОбъект();
			// 2022.04.04 1c_dev2 [start] 
			// Статус для найденного складского ордера устанавливается из Ожидаемой приемки 
			//ДокументОбъект.усСтатусДокумента 	= СтатусДокументаИзWMS;
			// 2022.04.04 1c_dev2 [end]
			ДокументОбъект.ax_КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
			ДокументОбъект.Товары.Очистить();
		Иначе
			ДокументОбъект 						= Документы.ax_СкладскойОрдер.СоздатьДокумент();
			ДокументОбъект.ВидОперации 			= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.ПриходныйОрдер;
			ДокументОбъект.Склад 				= ДокументОснование[ИмяРеквизитаСклад];
			ДокументОбъект.ДокументОснование 	= ДокументОснование;
			ДокументОбъект.усСтатусДокумента 	= СтатусДокументаИзWMS;
			ДокументОбъект.КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
			ДокументОбъект.Дата 				= Object.Date;
			ДокументОбъект.Номер 				= Object.Number;
		КонецЕсли;	
			
		Для Каждого СтрокаОбъектаXDTO Из Object.GoodsLine Цикл
			
			КодСтроки 			= Число(СтрокаОбъектаXDTO.LineNum);
			КоличествоФакт 		= СтрокаОбъектаXDTO.QuantityFact;
			
			СтруктураПоискаСтроки = Новый Структура("КодСтроки",КодСтроки);
			
			мсвНайденныхСтрок = ДокументОбъект.Товары.НайтиСтроки(СтруктураПоискаСтроки);
			Если мсвНайденныхСтрок.Количество()>0 Тогда
				
				мсвНайденныхСтрок[0].КоличествоФакт = КоличествоФакт;
				
			Иначе

				Если Object.DocumentType = "Приемка из производства" Тогда // приемка из комплектации, по документу принимается только один товар
					
					// Новая строка
					СтрокаДокумента 					= ДокументОбъект.Товары.Добавить();
					СтрокаДокумента.Номенклатура 		= ДокументОснование.Номенклатура;
					СтрокаДокумента.ЕдиницаИзмерения 	= ДокументОснование.ЕдиницаИзмерения;
					СтрокаДокумента.КодСтроки		 	= "";
					СтрокаДокумента.КоличествоФакт	 	= КоличествоФакт;
					
				Иначе
	            	
					СтрокаТЧ_ДокументОснование = ДокументОснование.Товары.Найти(КодСтроки, "КодСтроки");	
					
					Если СтрокаТЧ_ДокументОснование = Неопределено Тогда
						// Лишнее не отражаем
						Продолжить;
					КонецЕсли;	
					
					// Новая строка
					СтрокаДокумента 					= ДокументОбъект.Товары.Добавить();
					СтрокаДокумента.Номенклатура 		= СтрокаТЧ_ДокументОснование.Номенклатура;
					СтрокаДокумента.ЕдиницаИзмерения 	= СтрокаТЧ_ДокументОснование.ЕдиницаИзмерения;
					СтрокаДокумента.КодСтроки		 	= СтрокаТЧ_ДокументОснование.КодСтроки;
					СтрокаДокумента.КоличествоФакт	 	= КоличествоФакт;
					
				КонецЕсли;
				
			КонецЕсли;	
			
		КонецЦикла;	
		
		усСхождение = Истина;
		
		табПроверкаСхождения = Новый ТаблицаЗначений();
		табПроверкаСхождения.Колонки.Добавить("КодСтроки");
		табПроверкаСхождения.Колонки.Добавить("Количество");
		табПроверкаСхождения.Колонки.Добавить("КоличествоФакт");
		
		Для Каждого СтрокаСкладскойОрдер Из ДокументОбъект.Товары Цикл
			
			СтрокаТабПроверки 					= табПроверкаСхождения.Добавить();
			СтрокаТабПроверки.КодСтроки 		= СтрокаСкладскойОрдер.КодСтроки;
			СтрокаТабПроверки.КоличествоФакт 	= СтрокаСкладскойОрдер.КоличествоФакт;
			СтрокаТабПроверки.Количество 		= 0;
			
		КонецЦикла;	
		
		Если Object.DocumentType = "Приемка из производства" Тогда
			
			СтрокаТабПроверки 					= табПроверкаСхождения.Добавить();
			СтрокаТабПроверки.КодСтроки 		= "";
			СтрокаТабПроверки.Количество 		= ДокументОснование.Количество;
			СтрокаТабПроверки.КоличествоФакт 	= 0;
			
		Иначе
			Для Каждого СтрокаДокументОснование Из ДокументОснование.Товары Цикл
				
				СтрокаТабПроверки 					= табПроверкаСхождения.Добавить();
				СтрокаТабПроверки.КодСтроки 		= СтрокаДокументОснование.КодСтроки;
				СтрокаТабПроверки.Количество 		= СтрокаДокументОснование.Количество;
				СтрокаТабПроверки.КоличествоФакт 	= 0;
				
			КонецЦикла;	
		КонецЕсли;
		
		табПроверкаСхождения.Свернуть("КодСтроки", "Количество, КоличествоФакт");
		
		Для Каждого СтрокаПроверки Из табПроверкаСхождения Цикл
			
			Если СтрокаПроверки.Количество <> СтрокаПроверки.КоличествоФакт Тогда
				усСхождение = Ложь;
			КонецЕсли;	
			
		КонецЦикла;	
		
		ДокументОбъект.усСходитсяПланФакт = усСхождение;
				
		ДокументОбъект.ОбменДанными.Загрузка = Истина;
		ДокументОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
		
		Возврат Истина;
		
	Исключение
		
		ОтменитьТранзакцию();
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("axExchange", УровеньЖурналаРегистрации.Ошибка, , ,"SetArrivalFact(): " + ОписаниеОшибки);
		Возврат Ложь;
		
	КонецПопытки;
КонецФункции // SetArrivalFact()

// Загрузка факта отгрузки
//
Функция _SetFactShipment(Object, NodeID)
	
	Попытка
		
		Если Object.DocumentType = "Отгрузка клиенту" Тогда
			ИмяДокумента 		= "РеализацияТоваровУслуг";
			ИмяРеквизитаСклад 	= "Склад";
		ИначеЕсли Object.DocumentType = "Самовывоз" Тогда
			ИмяДокумента 		= "РеализацияТоваровУслуг";
			ИмяРеквизитаСклад 	= "Склад";
		ИначеЕсли Object.DocumentType = "Отгрузка на склад" Тогда
			ИмяДокумента 		= "ПеремещениеТоваров";
			ИмяРеквизитаСклад 	= "СкладОтправитель";
		ИначеЕсли Object.DocumentType = "Списание" Тогда
			ИмяДокумента 		= "СписаниеТоваров";
			ИмяРеквизитаСклад 	= "Склад";
		ИначеЕсли Object.DocumentType = "Корректировка реализации" Тогда
			ИмяДокумента = "КорректировкаРеализации";
			ИмяРеквизитаСклад = "Склад";
		ИначеЕсли Object.DocumentType = "Отгрузка в производство" Тогда
			ИмяДокумента = "КомплектацияНоменклатуры";
			ИмяРеквизитаСклад = "Склад";
		Иначе
			Возврат Истина;
		КонецЕсли;		
		
		НачатьТранзакцию();
		
		ДокументОснование 		= Документы[ИмяДокумента].ПолучитьСсылку(Новый УникальныйИдентификатор(Object.ID));
		СтатусДокументаИзWMS 	= СопоставитьСтатусWMS4_ОжидаемаяПриемка(Object.Status);
		
		//ЗаписьЖурналаРегистрации("WMS_Status", УровеньЖурналаРегистрации.Ошибка, , ДокументОснование, Строка(ДокументОснование) + " = " + Строка(Object.Status));
		
		Запрос = Новый Запрос();
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ax_СкладскойОрдер.Ссылка КАК ДокументСсылка
		|ИЗ
		|	Документ.ax_СкладскойОрдер КАК ax_СкладскойОрдер
		|ГДЕ
		|	ax_СкладскойОрдер.ДокументОснование = &ДокументОснование
		|	И ax_СкладскойОрдер.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ТДФ_ВидОперацииСкладскойОрдерWMS.РасходныйОрдер)
		|	И НЕ ax_СкладскойОрдер.ПометкаУдаления";
		
		Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			ДокументОбъект = Выборка.ДокументСсылка.ПолучитьОбъект();
			ДокументОбъект.усСтатусДокумента 	= СтатусДокументаИзWMS;
			//ДокументОбъект.ax_КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
			ДокументОбъект.КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description);
			ДокументОбъект.Товары.Очистить();
		Иначе
			ДокументОбъект 						= Документы.ax_СкладскойОрдер.СоздатьДокумент();
			ДокументОбъект.ВидОперации 			= Перечисления.ТДФ_ВидОперацииСкладскойОрдерWMS.РасходныйОрдер;
			ДокументОбъект.Склад 				= ДокументОснование[ИмяРеквизитаСклад];
			ДокументОбъект.ДокументОснование 	= ДокументОснование;
			ДокументОбъект.усСтатусДокумента 	= СтатусДокументаИзWMS;
			//ДокументОбъект.ax_КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
			ДокументОбъект.КомментарийСклад 	= ОбменДаннымиWMS4.ОбработатьКомментарий(Object.Description); // 2022.08.17 1c_dev2 записать многострочного комментария
			ДокументОбъект.Дата 				= Object.Date;
			ДокументОбъект.Номер 				= Object.Number;
		КонецЕсли;	
			
		Для Каждого СтрокаОбъектаXDTO Из Object.GoodsLine Цикл
			
			КодСтроки 			= Число(СтрокаОбъектаXDTO.LineNum);
			КоличествоФакт 		= СтрокаОбъектаXDTO.QuantityFact;
			
			//ЗаписьЖурналаРегистрации("WMS_Количество", УровеньЖурналаРегистрации.Ошибка, , ДокументОснование, "Код строки: " + Строка(КодСтроки) + ", количество: " + Строка(КоличествоФакт));
			
			// СтруктураПоискаСтроки = Новый Структура("КодСтроки",КодСтроки);
			// код строки у документов имеет тип число
			СтруктураПоискаСтроки = Новый Структура("КодСтроки",КодСтроки);
			
			мсвНайденныхСтрок = ДокументОбъект.Товары.НайтиСтроки(СтруктураПоискаСтроки);
			Если мсвНайденныхСтрок.Количество()>0 Тогда
				
				мсвНайденныхСтрок[0].КоличествоФакт = КоличествоФакт;
				
			Иначе      
				
				Если Object.DocumentType = "Отгрузка в производство" Тогда // отгрузка в производство, по документу отгружаются комплектующие
					СтрокаТЧ_ДокументОснование = ДокументОснование.Комплектующие.Найти(КодСтроки, "КодСтроки");	
				Иначе
					СтрокаТЧ_ДокументОснование = ДокументОснование.Товары.Найти(КодСтроки, "КодСтроки");	
				КонецЕсли;
					
				Если СтрокаТЧ_ДокументОснование = Неопределено Тогда
					// Лишнее не отражаем
					Продолжить;
				КонецЕсли;	
				
				ЕдиницаИзмерения = ?(
					СтрокаТЧ_ДокументОснование.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
				    СтрокаТЧ_ДокументОснование.Упаковка,
					СтрокаТЧ_ДокументОснование.Номенклатура.ЕдиницаИзмерения
				);
				
				// Новая строка
				СтрокаДокумента 					= ДокументОбъект.Товары.Добавить();
				СтрокаДокумента.Номенклатура 		= СтрокаТЧ_ДокументОснование.Номенклатура;
				СтрокаДокумента.ЕдиницаИзмерения 	= ЕдиницаИзмерения;
				СтрокаДокумента.КодСтроки		 	= СтрокаТЧ_ДокументОснование.КодСтроки;
				СтрокаДокумента.КоличествоФакт	 	= КоличествоФакт;
				
			КонецЕсли;

		КонецЦикла;	
		
		усСхождение = Истина;
		
		табПроверкаСхождения = Новый ТаблицаЗначений();
		табПроверкаСхождения.Колонки.Добавить("КодСтроки");
		табПроверкаСхождения.Колонки.Добавить("Количество");
		табПроверкаСхождения.Колонки.Добавить("КоличествоФакт");
		
		Для Каждого СтрокаСкладскойОрдер Из ДокументОбъект.Товары Цикл
			
			СтрокаТабПроверки 					= табПроверкаСхождения.Добавить();
			СтрокаТабПроверки.КодСтроки 		= СтрокаСкладскойОрдер.КодСтроки;
			СтрокаТабПроверки.КоличествоФакт 	= СтрокаСкладскойОрдер.КоличествоФакт;
			СтрокаТабПроверки.Количество 		= 0;
			
		КонецЦикла;	

		Если Object.DocumentType = "Отгрузка в производство" Тогда
			Для Каждого СтрокаДокументОснование Из ДокументОснование.Комплектующие Цикл
				
				СтрокаТабПроверки 					= табПроверкаСхождения.Добавить();
				СтрокаТабПроверки.КодСтроки 		= СтрокаДокументОснование.КодСтроки;
				СтрокаТабПроверки.Количество 		= СтрокаДокументОснование.Количество;
				СтрокаТабПроверки.КоличествоФакт 	= 0;
				
			КонецЦикла;	
		Иначе
			Для Каждого СтрокаДокументОснование Из ДокументОснование.Товары Цикл
				
				СтрокаТабПроверки 					= табПроверкаСхождения.Добавить();
				СтрокаТабПроверки.КодСтроки 		= СтрокаДокументОснование.КодСтроки;
				СтрокаТабПроверки.Количество 		= СтрокаДокументОснование.Количество;
				СтрокаТабПроверки.КоличествоФакт 	= 0;
				
			КонецЦикла;	
		КонецЕсли;
		
		табПроверкаСхождения.Свернуть("КодСтроки", "Количество, КоличествоФакт");
		
		Для Каждого СтрокаПроверки Из табПроверкаСхождения Цикл
			
			Если СтрокаПроверки.Количество <> СтрокаПроверки.КоличествоФакт Тогда
				усСхождение = Ложь;
				Прервать;
			КонецЕсли;	
			
		КонецЦикла;	
		
		ДокументОбъект.усСходитсяПланФакт = усСхождение;
				
		ДокументОбъект.ОбменДанными.Загрузка = Истина;
		ДокументОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
		
		Возврат Истина;
		
	Исключение
		
		ОтменитьТранзакцию();
		ОписаниеОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("axExchange", УровеньЖурналаРегистрации.Ошибка, , ,"SetFactShipment(): " + ОписаниеОшибки);
		Возврат Ложь;
		
	КонецПопытки;
КонецФункции

