#Область ПрограммныйИнтерфейс

// Создает приходные ордера на товары при их отсутствии и заполняет их товарами к приемке.
// При передаче статуса "Отменена" отменяет проведение ордеров.
//
// Параметры:
//   СозданиеОрдераСтруктура - Структура - параметры создания ордеров и результата:
//                             * ДокументОснования - ДокументСсылка - документ основания
//                             * ДатаДокументаВWMS - Дата - дата документа в WMS
//                             * НомерДокументаВWMS - Строка - номер документа в WMS
//                             * Комментарий - Строка - комментарий для ордера
//                             * ТекстСообщения - Строка - текст сообщения (возвращаемое значение)
//                             * Результат - Булево - признак успешного выполнения (возвращаемое значение)
//                             * Ошибка - Булево - признак ошибки (возвращаемое значение)
//   СтатусОжидаемойПриемки - Строка, Неопределено - статус ожидаемой приемки. При значении "Отменена" отменяется проведение ордеров
Процедура УстановитьФактПриемки(СозданиеОрдераСтруктура, СтатусОжидаемойПриемки = Неопределено) Экспорт
	
	ШаблонТекста = "Приходные ордера на отгрузку не созданы";
	
	НачатьТранзакцию();
	Попытка
		ЗапросТекст = 
		"ВЫБРАТЬ
		|	ТоварыКПоступлению.Регистратор КАК Регистратор,
		|	ТоварыКПоступлению.ДокументПоступления КАК ДокументПоступления,
		|	ТоварыКПоступлению.Склад КАК Склад,
		|	ТоварыКПоступлению.Отправитель КАК Отправитель,
		|	ТоварыКПоступлению.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ втТоварыКПоступлению
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению КАК ТоварыКПоступлению
		|ГДЕ
		|	ТоварыКПоступлению.Регистратор = &ДокументОснования
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКПоступлению.Номенклатура,
		|	ТоварыКПоступлению.Отправитель,
		|	ТоварыКПоступлению.Склад,
		|	ТоварыКПоступлению.ДокументПоступления,
		|	ТоварыКПоступлению.Регистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКПоступлениюОбороты.Регистратор КАК Регистратор,
		|	ТоварыКПоступлениюОбороты.ДокументПоступления КАК ДокументПоступления,
		|	ТоварыКПоступлениюОбороты.Склад КАК Склад,
		|	ТоварыКПоступлениюОбороты.Отправитель КАК Отправитель
		|ПОМЕСТИТЬ втТоварыКПоступлениюОбороты
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Обороты(
		|			,
		|			,
		|			Регистратор,
		|			(ДокументПоступления, Склад, Отправитель) В
		|				(ВЫБРАТЬ
		|					втТоварыКПоступлению.ДокументПоступления КАК ДокументПоступления,
		|					втТоварыКПоступлению.Склад КАК Склад,
		|					втТоварыКПоступлению.Отправитель КАК Отправитель
		|				ИЗ
		|					втТоварыКПоступлению КАК втТоварыКПоступлению)) КАК ТоварыКПоступлениюОбороты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКПоступлениюОбороты.Регистратор КАК КОформлениюПоступленийРегистратор,
		|	ТоварыКПоступлениюОбороты.Склад КАК Склад,
		|	ТоварыКПоступлениюОбороты.Отправитель КАК Отправитель,
		|	ТоварыКПоступлениюОбороты.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	ТоварыКПоступлениюОбороты.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлениюОбороты.Характеристика КАК Характеристика,
		|	ТоварыКПоступлениюОбороты.Назначение КАК Назначение,
		|	ТоварыКПоступлениюОбороты.Серия КАК Серия,
		|	ТоварыКПоступлениюОбороты.КОформлениюПоступленийПоРаспоряжениюРасход КАК КОформлениюПоступленийПоРаспоряжению
		|ПОМЕСТИТЬ втКОформлениюПоступленийПоРаспоряжениюРасход
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Обороты(
		|			,
		|			,
		|			Регистратор,
		|			ДокументПоступления В
		|				(ВЫБРАТЬ
		|					втТоварыКПоступлениюОбороты.Регистратор КАК Регистратор
		|				ИЗ
		|					втТоварыКПоступлениюОбороты КАК втТоварыКПоступлениюОбороты)) КАК ТоварыКПоступлениюОбороты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКПоступлениюОстатки.ДокументПоступления КАК ДокументПоступления,
		|	ТоварыКПоступлениюОстатки.Склад КАК Склад,
		|	ТоварыКПоступлениюОстатки.Отправитель КАК Отправитель,
		|	ТоварыКПоступлениюОстатки.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	ТоварыКПоступлениюОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлениюОстатки.Характеристика КАК Характеристика,
		|	ТоварыКПоступлениюОстатки.Назначение КАК Назначение,
		|	ТоварыКПоступлениюОстатки.Серия КАК Серия,
		|	ТоварыКПоступлениюОстатки.КОформлениюОрдеровОстаток КАК КОформлениюОрдеровОстаток
		|ПОМЕСТИТЬ втКОформлениюОрдеровОстаток
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Остатки(
		|			,
		|			ДокументПоступления В
		|				(ВЫБРАТЬ
		|					втТоварыКПоступлениюОбороты.Регистратор КАК Регистратор
		|				ИЗ
		|					втТоварыКПоступлениюОбороты КАК втТоварыКПоступлениюОбороты)) КАК ТоварыКПоступлениюОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКПоступлениюОбороты.Регистратор КАК ПриходныйОрдер,
		|	ТоварыКПоступлениюОбороты.ДокументПоступления КАК ДокументПоступления,
		|	ТоварыКПоступлениюОбороты.Склад КАК Склад,
		|	ТоварыКПоступлениюОбороты.Отправитель КАК Отправитель,
		|	ТоварыКПоступлениюОбороты.КОформлениюОрдеровРасход КАК Количество,
		|	ИСТИНА КАК Принят
		|ПОМЕСТИТЬ втПриходныйОрдерПринят
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Обороты(
		|			,
		|			,
		|			Регистратор,
		|			ДокументПоступления В
		|				(ВЫБРАТЬ
		|					втТоварыКПоступлениюОбороты.Регистратор КАК Регистратор
		|				ИЗ
		|					втТоварыКПоступлениюОбороты КАК втТоварыКПоступлениюОбороты)) КАК ТоварыКПоступлениюОбороты
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ТоварыКПоступлениюОбороты.Регистратор,
		|	ТоварыКПоступлениюОбороты.ДокументПоступления,
		|	ТоварыКПоступлениюОбороты.Склад,
		|	ТоварыКПоступлениюОбороты.Отправитель,
		|	ТоварыКПоступлениюОбороты.ПринимаетсяОборот,
		|	ЛОЖЬ
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Обороты(
		|			,
		|			,
		|			Регистратор,
		|			ДокументПоступления В
		|				(ВЫБРАТЬ
		|					втТоварыКПоступлениюОбороты.Регистратор КАК Регистратор
		|				ИЗ
		|					втТоварыКПоступлениюОбороты КАК втТоварыКПоступлениюОбороты)) КАК ТоварыКПоступлениюОбороты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втПриходныйОрдерПринят.ПриходныйОрдер КАК ПриходныйОрдер,
		|	втПриходныйОрдерПринят.ДокументПоступления КАК ДокументПоступления,
		|	втПриходныйОрдерПринят.Склад КАК Склад,
		|	втПриходныйОрдерПринят.Отправитель КАК Отправитель,
		|	втПриходныйОрдерПринят.Количество КАК Количество,
		|	втПриходныйОрдерПринят.Принят КАК Принят
		|ИЗ
		|	втПриходныйОрдерПринят КАК втПриходныйОрдерПринят
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втТоварыКПоступлению.Регистратор КАК ДокументОснования,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.КОформлениюПоступленийРегистратор КАК КОформлениюПоступленийРегистратор,
		|	втКОформлениюОрдеровОстаток.ДокументПоступления КАК Распоряжение,
		|	втТоварыКПоступлению.Склад КАК Склад,
		|	втТоварыКПоступлению.Отправитель КАК Отправитель,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.Номенклатура КАК Номенклатура,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.Характеристика КАК Характеристика,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.Назначение КАК Назначение,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.Серия КАК Серия,
		|	втКОформлениюПоступленийПоРаспоряжениюРасход.КОформлениюПоступленийПоРаспоряжению КАК КоличествоФакт,
		|	втКОформлениюОрдеровОстаток.КОформлениюОрдеровОстаток КАК КоличествоПлан
		|ИЗ
		|	втТоварыКПоступлению КАК втТоварыКПоступлению
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втКОформлениюПоступленийПоРаспоряжениюРасход КАК втКОформлениюПоступленийПоРаспоряжениюРасход
		|		ПО втТоварыКПоступлению.Склад = втКОформлениюПоступленийПоРаспоряжениюРасход.Склад
		|			И втТоварыКПоступлению.Отправитель = втКОформлениюПоступленийПоРаспоряжениюРасход.Отправитель
		|			И втТоварыКПоступлению.Номенклатура = втКОформлениюПоступленийПоРаспоряжениюРасход.Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втКОформлениюОрдеровОстаток КАК втКОформлениюОрдеровОстаток
		|		ПО втТоварыКПоступлению.Склад = втКОформлениюОрдеровОстаток.Склад
		|			И втТоварыКПоступлению.Отправитель = втКОформлениюОрдеровОстаток.Отправитель
		|			И втТоварыКПоступлению.Номенклатура = втКОформлениюОрдеровОстаток.Номенклатура";		
		
		Запрос = Новый Запрос (ЗапросТекст);
		Запрос.УстановитьПараметр("ДокументОснования", СозданиеОрдераСтруктура.ДокументОснования);
		МассивРезультатЗапроса = Запрос.ВыполнитьПакет();
		
		ТаблицаПринимаемыеТовары = МассивРезультатЗапроса[5].Выгрузить();
		ТаблицаТоварыКОформлениюОрдеровОстаток = МассивРезультатЗапроса[6].Выгрузить();
		
		ПриходныеОрдера = Новый Массив;
		
		Если ТаблицаПринимаемыеТовары.Количество() > 0 Тогда 
						
			Для Каждого СтрокаТаблицы Из ТаблицаПринимаемыеТовары Цикл 
				Если НЕ СтрокаТаблицы.Принят Тогда 
					ПриходныеОрдера.Добавить(СтрокаТаблицы.	ПриходныйОрдер);
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
				
		Если ТаблицаТоварыКОформлениюОрдеровОстаток.Количество() > 0 И ПриходныеОрдера.Количество() = 0 Тогда 
			
			ТаблицаДанныеСозданияОрдера = ТаблицаТоварыКОформлениюОрдеровОстаток
				.Скопировать(,"ДокументОснования, Распоряжение, Склад, Отправитель, ХозяйственнаяОперация");
			
			ТаблицаДанныеСозданияОрдера.Свернуть("ДокументОснования, Распоряжение, Склад, Отправитель, ХозяйственнаяОперация");	
			
			СтрокиТаблицыДанныеСозданияОрдера = ТаблицаДанныеСозданияОрдера
				.НайтиСтроки(Новый Структура("ДокументОснования", СозданиеОрдераСтруктура.ДокументОснования));
			
			Для Каждого СтрокаТаблицы Из СтрокиТаблицыДанныеСозданияОрдера Цикл 
				
				ДанныеЗаполнения = Новый Структура;
				ДанныеЗаполнения.Вставить("Склад", СтрокаТаблицы.Склад);
				ДанныеЗаполнения.Вставить("Распоряжение", СтрокаТаблицы.Распоряжение);
				ДанныеЗаполнения.Вставить("Отправитель", СтрокаТаблицы.Отправитель);
				ДанныеЗаполнения.Вставить("ХозяйственнаяОперация", СтрокаТаблицы.ХозяйственнаяОперация);
				ДанныеЗаполнения.Вставить("ДатаВходящегоДокумента", СозданиеОрдераСтруктура.ДатаДокументаВWMS);
				ДанныеЗаполнения.Вставить("НомерВходящегоДокумента", СозданиеОрдераСтруктура.НомерДокументаВWMS);
				
				ОбъектПриходныйОрдер = Документы.ПриходныйОрдерНаТовары.СоздатьДокумент();
				ОбъектПриходныйОрдер.Заполнить(ДанныеЗаполнения);
				ОбъектПриходныйОрдер.Дата = ТекущаяДатаСеанса();
				ОбъектПриходныйОрдер.Записать(РежимЗаписиДокумента.Проведение);

				ПриходныеОрдера.Добавить(ОбъектПриходныйОрдер.Ссылка);
				
			КонецЦикла;
						
		КонецЕсли;
		
		Если ПриходныеОрдера.Количество() = 0 Тогда 
						
			Если ТаблицаПринимаемыеТовары.Количество() <> 0 Тогда 
				
				ТекстСообщения = СтрШаблон("%1 по причине:
					|%2", ШаблонТекста, "- все товары уже принимаются (приняты).");
				
				СозданиеОрдераСтруктура.ТекстСообщения	= ?(ПустаяСтрока(СозданиеОрдераСтруктура.ТекстСообщения),
					ТекстСообщения,
					СтрШаблон("%1:
						|%2", ТекстСообщения, СозданиеОрдераСтруктура.ТекстСообщения));		
				
			Иначе				
				ВызватьИсключение "не оформлены накладные";
			КонецЕсли;
			
		КонецЕсли;
		
		Для Каждого ПриходныйОрдер Из ПриходныеОрдера Цикл 	
			ПриходныйОрдерОбъект = ПриходныйОрдер.ПолучитьОбъект();
			ПриходныйОрдерОбъект.Заблокировать();
			
			Если СтатусОжидаемойПриемки = "Отменена" ИЛИ ПриходныеОрдера.Найти(ПриходныйОрдер) <> 0 Тогда 
				ПриходныйОрдерОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				Продолжить;	
			КонецЕсли;
			
			ТаблицаТоварыКПриемке = ПриходныйОрдерОбъект.Товары.ВыгрузитьКолонки(); // СкопироватьКолонки
			
			Для Каждого СтрокаТаблицыТоварыКОформлениюОрдеровОстаток Из ТаблицаТоварыКОформлениюОрдеровОстаток Цикл 
				СтрокаТаблицыТоварыКПриемке = ТаблицаТоварыКПриемке.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицыТоварыКПриемке, СтрокаТаблицыТоварыКОформлениюОрдеровОстаток);
				
				КоличествоКПриемке = ?(
					СтрокаТаблицыТоварыКОформлениюОрдеровОстаток.КоличествоФакт > СтрокаТаблицыТоварыКОформлениюОрдеровОстаток.КоличествоПлан,
					СтрокаТаблицыТоварыКОформлениюОрдеровОстаток.КоличествоПлан, СтрокаТаблицыТоварыКОформлениюОрдеровОстаток.КоличествоФакт
				);
				
				СтрокаТаблицыТоварыКПриемке.Количество = КоличествоКПриемке;
				СтрокаТаблицыТоварыКПриемке.КоличествоУпаковок = КоличествоКПриемке;
				
			КонецЦикла;
						
			Если СтатусОжидаемойПриемки <> Неопределено Тогда 
				
				Значения = Новый Структура("Статус, Комментарий",
					СоответствиеСтатусовОжидаемойПриемкиПриходныхОрдеров(СтатусОжидаемойПриемки),
					СозданиеОрдераСтруктура.Комментарий);
					
				ЗаполнитьЗначенияСвойств(ПриходныйОрдерОбъект, Значения);
	
			КонецЕсли; 
			
			ПриходныйОрдерОбъект.Товары.Очистить();				
			ПриходныйОрдерОбъект.Товары.Загрузить(ТаблицаТоварыКПриемке);
			ПриходныйОрдерОбъект.Записать(РежимЗаписиДокумента.Проведение);

		КонецЦикла;
		
		СозданиеОрдераСтруктура.Результат = Истина;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстСообщения = СтрШаблон("%1 по причине:
				|- %2.", ШаблонТекста, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		СозданиеОрдераСтруктура.Ошибка = Истина;
		СозданиеОрдераСтруктура.ТекстСообщения = ТекстСообщения;
				
	КонецПопытки;
		
КонецПроцедуры	

// Создает или переоформляет расходные ордера на товары по документу-основанию на основании данных из WMS-системы.
//
// Параметры:
//   СозданиеОрдераСтруктура - Структура - входные и выходные данные для создания/оформления расходных ордеров:
//     * ДокументОснования - ДокументСсылка - документ-основание для создания ордеров
//     * СтатусДокументаВWMS - Строка - статус документа в WMS-системе
//     * ДатаДокументаВWMS - Дата - дата документа из WMS-системы
//     * Комментарий - Строка - комментарий к документу
//     * ТекстСообщения - Строка - текст сообщения об ошибке (входной и выходной параметр)
//     * Результат - Булево - признак успешного выполнения (выходной параметр)
//     * Ошибка - Булево - признак наличия ошибки (выходной параметр)
Процедура УстановитьФактОтгрузки(СозданиеОрдераСтруктура) Экспорт
	
	ШаблонТекста = "Расходные ордера на отгрузку не созданы";
		
	НачатьТранзакцию();
	Попытка		
		ЗапросТекст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузке.ВидДвижения КАК ВидДвижения,
		|	ТоварыКОтгрузке.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ТоварыКОтгрузке.Склад КАК Склад,
		|	ТоварыКОтгрузке.Получатель КАК Получатель,
		|	ТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузке.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузке.Назначение КАК Назначение,
		|	ТоварыКОтгрузке.Серия КАК Серия,
		|	ТоварыКОтгрузке.Регистратор КАК ДокументОснования,
		|	ТоварыКОтгрузке.КОформлению КАК КОформлению
		|ПОМЕСТИТЬ втТоварыКОтгрузке
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|ГДЕ
		|	ТоварыКОтгрузке.Регистратор = &ДокументОснования
		|	И ТоварыКОтгрузке.ВидДвижения = &ВидДвижения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКОтгрузкеОстатки.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ТоварыКОтгрузкеОстатки.Склад КАК Склад,
		|	ТоварыКОтгрузкеОстатки.Получатель КАК Получатель,
		|	ТоварыКОтгрузкеОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузкеОстатки.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузкеОстатки.Назначение КАК Назначение,
		|	ТоварыКОтгрузкеОстатки.Серия КАК Серия,
		|	ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток КАК КОтгрузкеОстаток,
		|	ТоварыКОтгрузкеОстатки.СобираетсяОстаток + ТоварыКОтгрузкеОстатки.СобраноОстаток КАК ОтгружаетсяОстаток
		|ПОМЕСТИТЬ втТоварыКОтгрузкеОстатки
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке.Остатки(
		|			,
		|			(ДокументОтгрузки, Склад, Получатель, Номенклатура, Характеристика, Серия, Назначение) В
		|				(ВЫБРАТЬ
		|					втТоварыКОтгрузке.ДокументОтгрузки КАК ДокументОтгрузки,
		|					втТоварыКОтгрузке.Склад КАК Склад,
		|					втТоварыКОтгрузке.Получатель КАК Получатель,
		|					втТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|					втТоварыКОтгрузке.Характеристика КАК Характеристика,
		|					втТоварыКОтгрузке.Серия КАК Серия,
		|					втТоварыКОтгрузке.Назначение КАК Назначение
		|				ИЗ
		|					втТоварыКОтгрузке КАК втТоварыКОтгрузке)) КАК ТоварыКОтгрузкеОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКОтгрузке.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ТоварыКОтгрузке.Склад КАК Склад,
		|	ТоварыКОтгрузке.Получатель КАК Получатель,
		|	ТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузке.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузке.Назначение КАК Назначение,
		|	ТоварыКОтгрузке.Серия КАК Серия,
		|	ТоварыПоРаспоряжениям.Ссылка КАК РасходныйОрдер,
		|	СУММА(ТоварыПоРаспоряжениям.Количество) КАК КоличествоОтгружается
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК ТоварыПоРаспоряжениям
		|		ПО ТоварыКОтгрузке.Регистратор = ТоварыПоРаспоряжениям.Ссылка
		|			И ТоварыКОтгрузке.ДокументОтгрузки = ТоварыПоРаспоряжениям.Распоряжение
		|			И ТоварыКОтгрузке.Номенклатура = ТоварыПоРаспоряжениям.Номенклатура
		|			И ТоварыКОтгрузке.Характеристика = ТоварыПоРаспоряжениям.Характеристика
		|			И ТоварыКОтгрузке.Серия = ТоварыПоРаспоряжениям.Серия
		|			И ТоварыКОтгрузке.Назначение = ТоварыПоРаспоряжениям.Назначение
		|ГДЕ
		|	(ТоварыКОтгрузке.ДокументОтгрузки, 
		|		ТоварыКОтгрузке.Склад, 
		|		ТоварыКОтгрузке.Получатель, 
		|		ТоварыКОтгрузке.Номенклатура, 
		|		ТоварыКОтгрузке.Характеристика, 
		|		ТоварыКОтгрузке.Серия, 
		|		ТоварыКОтгрузке.Назначение) В
		|			(ВЫБРАТЬ
		|				втТоварыКОтгрузке.ДокументОтгрузки КАК ДокументОтгрузки,
		|				втТоварыКОтгрузке.Склад КАК Склад,
		|				втТоварыКОтгрузке.Получатель КАК Получатель,
		|				втТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|				втТоварыКОтгрузке.Характеристика КАК Характеристика,
		|				втТоварыКОтгрузке.Серия КАК Серия,
		|				втТоварыКОтгрузке.Назначение КАК Назначение
		|			ИЗ
		|				втТоварыКОтгрузке КАК втТоварыКОтгрузке)
		|	И ТоварыКОтгрузке.КОтгрузке = 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыПоРаспоряжениям.Ссылка,
		|	ТоварыКОтгрузке.ДокументОтгрузки,
		|	ТоварыКОтгрузке.Склад,
		|	ТоварыКОтгрузке.Получатель,
		|	ТоварыКОтгрузке.Номенклатура,
		|	ТоварыКОтгрузке.Характеристика,
		|	ТоварыКОтгрузке.Назначение,
		|	ТоварыКОтгрузке.Серия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втТоварыКОтгрузке.ДокументОснования КАК ДокументОснования,
		|	втТоварыКОтгрузке.ДокументОтгрузки КАК Распоряжение,
		|	втТоварыКОтгрузке.Склад КАК Склад,
		|	втТоварыКОтгрузке.Получатель КАК Получатель,
		|	втТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		|	втТоварыКОтгрузке.Характеристика КАК Характеристика,
		|	втТоварыКОтгрузке.Назначение КАК Назначение,
		|	втТоварыКОтгрузке.Серия КАК Серия,
		|	СУММА(втТоварыКОтгрузкеОстатки.КОтгрузкеОстаток) КАК КоличествоПлан,
		|	СУММА(втТоварыКОтгрузке.КОформлению) КАК КоличествоФакт
		|ИЗ
		|	втТоварыКОтгрузке КАК втТоварыКОтгрузке
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втТоварыКОтгрузкеОстатки КАК втТоварыКОтгрузкеОстатки
		|		ПО втТоварыКОтгрузке.ДокументОтгрузки = втТоварыКОтгрузкеОстатки.ДокументОтгрузки
		|			И втТоварыКОтгрузке.Склад = втТоварыКОтгрузкеОстатки.Склад
		|			И втТоварыКОтгрузке.Получатель = втТоварыКОтгрузкеОстатки.Получатель
		|			И втТоварыКОтгрузке.Номенклатура = втТоварыКОтгрузкеОстатки.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	втТоварыКОтгрузке.ДокументОснования,
		|	втТоварыКОтгрузке.ДокументОтгрузки,
		|	втТоварыКОтгрузке.Склад,
		|	втТоварыКОтгрузке.Получатель,
		|	втТоварыКОтгрузке.Номенклатура,
		|	втТоварыКОтгрузке.Характеристика,
		|	втТоварыКОтгрузке.Назначение,
		|	втТоварыКОтгрузке.Серия";
		
		Запрос = Новый Запрос (ЗапросТекст);
		Запрос.УстановитьПараметр("ДокументОснования", СозданиеОрдераСтруктура.ДокументОснования);
		Запрос.УстановитьПараметр("ВидДвижения",  ВидДвиженияНакопления.Расход);
		МассивРезультатЗапроса = Запрос.ВыполнитьПакет();
		
		ТаблицаОтгружаемыеТовары = МассивРезультатЗапроса[2].Выгрузить();
		ТаблицаТоварыКОтгрузкеОстатки = МассивРезультатЗапроса[3].Выгрузить();
		
		РасходныеОрдера = Новый Массив;
		
		Если ТаблицаОтгружаемыеТовары.Количество() > 0 Тогда 
			
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(РасходныеОрдера, 
				ТаблицаОтгружаемыеТовары.ВыгрузитьКолонку("РасходныйОрдер"), Истина);	
			
		ИначеЕсли ТаблицаТоварыКОтгрузкеОстатки.Количество() > 0  Тогда 
			СтруктураПараметровСозданияРасходныхОрдеров = СкладыСервер.ПараметрыПереоформленияРасходныхОрдеров();
			
			ТаблицаДанныеСозданияРасходныхОрдеров = ТаблицаТоварыКОтгрузкеОстатки
				.Скопировать(,"ДокументОснования, Распоряжение, Склад, Получатель");
			
			ТаблицаДанныеСозданияРасходныхОрдеров.Свернуть("ДокументОснования, Распоряжение, Склад, Получатель");
			
			СтрокиТаблицыДанныеСозданияРасходныхОрдеров = ТаблицаДанныеСозданияРасходныхОрдеров
				.НайтиСтроки(Новый Структура("ДокументОснования", СозданиеОрдераСтруктура.ДокументОснования));
			
			СтруктураПараметровСозданияРасходныхОрдеров.Склад = СтрокиТаблицыДанныеСозданияРасходныхОрдеров[0].Склад;
			СтруктураПараметровСозданияРасходныхОрдеров.Получатель = СтрокиТаблицыДанныеСозданияРасходныхОрдеров[0].Получатель;	
			СтруктураПараметровСозданияРасходныхОрдеров.РаспоряженияНаОтгрузку.Добавить(
			СтрокиТаблицыДанныеСозданияРасходныхОрдеров[0].Распоряжение);	
			
			// создает новый ордер если ордер не существует, или 
			// переоформляет существующий (если существующий ордер в статусе "Подготовлен"), или 
			// ОформленныеОрдера пустая таблица (если ордер существует и он не в статусе "Подготовлен")
			СтруктураОформленныеОрдера = СкладыСервер.ПереоформитьРасходныеОрдера(СтруктураПараметровСозданияРасходныхОрдеров);
			
			Для Каждого СтрокаТаблицы Из СтруктураОформленныеОрдера.ОформленныеОрдера Цикл 
				РасходныеОрдера.Добавить(СтрокаТаблицы.РасходныйОрдер);	
			КонецЦикла;
		КонецЕсли;
		
		Если РасходныеОрдера.Количество() = 0 Тогда 
			
			ТекстСообщения = СтрШаблон("%1. Возможные причины:
				|- все товары уже собираются (собраны);
				|- не оформлены накладные", ШаблонТекста);
			
			СозданиеОрдераСтруктура.ТекстСообщения	= ?(ПустаяСтрока(СозданиеОрдераСтруктура.ТекстСообщения),
				СтрШаблон("%1: %2", ШаблонТекста, ТекстСообщения),
				СтрШаблон("%1:
					|%2", ТекстСообщения, СозданиеОрдераСтруктура.ТекстСообщения));

		КонецЕсли;
		
		Для Каждого РасходныйОрдер Из РасходныеОрдера Цикл 
			РасходныйОрдерОбъект = РасходныйОрдер.ПолучитьОбъект();
			РасходныйОрдерОбъект.Заблокировать();
			
			Если СозданиеОрдераСтруктура.СтатусДокументаВWMS = "Отменен" ИЛИ РасходныеОрдера.Найти(РасходныйОрдер) <> 0 Тогда
				РасходныйОрдерОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				Продолжить;
			КонецЕсли; 
			
			ТаблицаТоварыПоРаспоряжениям = РасходныйОрдерОбъект.ТоварыПоРаспоряжениям.ВыгрузитьКолонки(); // СкопироватьКолонки
			
			Для Каждого  СтрокаТаблицыТоварыКОтгрузкеОстатки Из ТаблицаТоварыКОтгрузкеОстатки Цикл 
				СтрокаТаблицыТоварыПоРаспоряжениям = ТаблицаТоварыПоРаспоряжениям.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицыТоварыПоРаспоряжениям, СтрокаТаблицыТоварыКОтгрузкеОстатки);
				
				КоличествоКОтгрузке = ?(
						СтрокаТаблицыТоварыКОтгрузкеОстатки.КоличествоФакт > СтрокаТаблицыТоварыКОтгрузкеОстатки.КоличествоПлан, 
						СтрокаТаблицыТоварыКОтгрузкеОстатки.КоличествоПлан, СтрокаТаблицыТоварыКОтгрузкеОстатки.КоличествоФакт);
						
				СтрокаТаблицыТоварыПоРаспоряжениям.Количество = КоличествоКОтгрузке;
			КонецЦикла;

			Значения = Новый Структура("Статус, ДатаОтгрузки, Комментарий",
				СоответствиеСтатусовЗаказНаОтгрузкуРасходныхОрдеров(СозданиеОрдераСтруктура.СтатусДокументаВWMS),
				СозданиеОрдераСтруктура.ДатаДокументаВWMS,
				СозданиеОрдераСтруктура.Комментарий);

			РасходныйОрдерОбъект.ТоварыПоРаспоряжениям.Очистить();
			РасходныйОрдерОбъект.ТоварыПоРаспоряжениям.Загрузить(ТаблицаТоварыПоРаспоряжениям);
			ЗаполнитьЗначенияСвойств(РасходныйОрдерОбъект, Значения);
			Документы.РасходныйОрдерНаТовары.ЗаполнитьОтгружаемыеТоварыПоТоварамПоРаспоряжениям(РасходныйОрдерОбъект);
			Документы.РасходныйОрдерНаТовары.ЗаполнитьДействиеВСтроках(РасходныйОрдерОбъект);			
			РасходныйОрдерОбъект.Записать(РежимЗаписиДокумента.Проведение);	
		КонецЦикла;
		
		СозданиеОрдераСтруктура.Результат = Истина;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстСообщения = СтрШаблон("%1 по причине:
				|- %2.", ШаблонТекста, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		СозданиеОрдераСтруктура.Ошибка = Истина;
		СозданиеОрдераСтруктура.ТекстСообщения = ТекстСообщения;
				
	КонецПопытки;
	
КонецПроцедуры

// Заполняет структуру для создания ордера поступления на основе данных из XDTO.
//
// Параметры:
//   ОбъектXDTO - ОбъектXDTO - данные документа из WMS (ID, DocumentType, Date, Number, Status, Description)
//   СозданиеОрдераСтруктура - Структура:
//     * ДокументОснования - ДокументСсылка - ссылка на документ основания
//     * ДокументОснованияПроведен - Булево - признак проведения документа основания
//     * ДатаДокументаВWMS - Дата - дата документа в системе WMS
//     * НомерДокументаВWMS - Строка - номер документа в системе WMS
//     * СтатусДокументаВWMS - Строка - статус документа в системе WMS
//     * Комментарий - Строка - комментарий к документу
//     * Ошибка - Булево - признак возникновения ошибки
//     * ТекстСообщения - Строка - текст сообщения об ошибке
Процедура ОбъектXDTOВСозданиеОрдераПоступлениеСтруктура(ОбъектXDTO, СозданиеОрдераСтруктура) Экспорт 
	 
	Ошибка = Ложь;
	
	ТекстСообщенияШаблон = СтрШаблон(
		"Не удалось сформировать данные приемки по УИД  ""%1"": ", ОбъектXDTO.ID);
	
	ТипДокументаОснования = ТипДокументаОснованияПоИсточникуПоступленияWMS(
		ОбъектXDTO.DocumentType);
	
	// пока не знаю как обрабатывать корректировку реализации и списание товаров
	Если ТипДокументаОснования = Неопределено Тогда 
		Ошибка = Истина;
		СозданиеОрдераСтруктура.ТекстСообщения = СтрШаблон("%1
			| - Корректировка или оприходование пока не обрабатываются", ТекстСообщенияШаблон);
	КонецЕсли;

	Если НЕ Ошибка Тогда 		
		
		ДокументСсылка = Документы[ТипДокументаОснования]
			.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ID));		
			
		Если Найти(Строка(ДокументСсылка), "<Объект не найден>") <> 0 Тогда
			Ошибка = Истина;
			СозданиеОрдераСтруктура.ТекстСообщения = СтрШаблон("%1
				| - Не удалось найти документ основания в базе по УИД", ТекстСообщенияШаблон);			
		Иначе						
			СозданиеОрдераСтруктура.ДокументОснования = ДокументСсылка;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ Ошибка Тогда 
		
		СтруктураЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			СозданиеОрдераСтруктура.ДокументОснования, "Ссылка.Представление, Проведен");	
			
		СозданиеОрдераСтруктура.ДокументОснованияПроведен = СтруктураЗначенияРеквизитов.Проведен;	
		
		Если НЕ СтруктураЗначенияРеквизитов.Проведен Тогда 
			СозданиеОрдераСтруктура.ТекстСообщения = СтрШаблон("%1
				| - Документ основания ""%2"" не проведен или помечен на удаление", 
			 	ТекстСообщенияШаблон, СтруктураЗначенияРеквизитов.СсылкаПредставление);		
		КонецЕсли;
				
		СозданиеОрдераСтруктура.ДатаДокументаВWMS = ОбъектXDTO.Date;
		СозданиеОрдераСтруктура.НомерДокументаВWMS = ОбъектXDTO.Number;
		СозданиеОрдераСтруктура.СтатусДокументаВWMS = ОбъектXDTO.Status;
		СозданиеОрдераСтруктура.Комментарий = ОбменДаннымиWMS4.ОбработатьКомментарий(ОбъектXDTO.Description);
		
	КонецЕсли;
	
	СозданиеОрдераСтруктура.Ошибка = Ошибка;
		
КонецПроцедуры

// Заполняет структуру создания ордера отгрузки данными из объекта XDTO, проверяет документ основания на существование и проведение.
//
// Параметры:
//   ОбъектXDTO - ОбъектXDTO - данные документа отгрузки WMS
//   СозданиеОрдераСтруктура - Структура - заполняемая структура см. ax_СинхронизацияПриемкиОтгрузкиТоваров.СозданиеОрдераСтруктура
Процедура ОбъектXDTOВСозданиеОрдераОтгрузкаСтруктура(ОбъектXDTO, СозданиеОрдераСтруктура) Экспорт
	
	Ошибка = Ложь;
	ШаблонТекста = "Не удалось сформировать данные отгрузки";
	
	ТипДокументаОснования  = ТипДокументаОснованияПоНаправлениюОтгрузкиWMS(ОбъектXDTO.DocumentType);
	
	// пока не знаю как обрабатывать корректировку реализации и списание товаров
	Если ТипДокументаОснования = Неопределено Тогда 
		Ошибка = Истина;
		СозданиеОрдераСтруктура.ТекстСообщения = СтрШаблон("%1 по УИД (ID) ""%2"":
			| - Корректировка или списание пока не обрабатываются", ШаблонТекста, ОбъектXDTO.ID);
	КонецЕсли;
	
	Если НЕ Ошибка Тогда 		
		
		ДокументСсылка = Документы[ТипДокументаОснования]
			.ПолучитьСсылку(Новый УникальныйИдентификатор(ОбъектXDTO.ID));		
			
		Если Найти(Строка(ДокументСсылка), "<Объект не найден>") <> 0 Тогда
			Ошибка = Истина;
			СозданиеОрдераСтруктура.ТекстСообщения = СтрШаблон("%1 по УИД (ID) ""%2"":
				| - Не удалось найти документ основания в базе по УИД", ШаблонТекста, ОбъектXDTO.ID);			
		Иначе						
			СозданиеОрдераСтруктура.ДокументОснования = ДокументСсылка;
		КонецЕсли;
		
	КонецЕсли;	
	
	Если НЕ Ошибка Тогда 
		
		СтруктураЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			СозданиеОрдераСтруктура.ДокументОснования, "Ссылка.Представление, Проведен");	
			
		СозданиеОрдераСтруктура.ДокументОснованияПроведен = СтруктураЗначенияРеквизитов.Проведен;	
		
		Если НЕ СтруктураЗначенияРеквизитов.Проведен Тогда 
			СозданиеОрдераСтруктура.ТекстСообщения = СтрШаблон("%1:
				| - Документ основания ""%2"" не проведен или помечен на удаление", 
			 	ШаблонТекста, СтруктураЗначенияРеквизитов.СсылкаПредставление);		
		КонецЕсли;
		
		СозданиеОрдераСтруктура.ДатаДокументаВWMS = ОбъектXDTO.Date;
		СозданиеОрдераСтруктура.НомерДокументаВWMS = ОбъектXDTO.Number;
		СозданиеОрдераСтруктура.СтатусДокументаВWMS = ОбъектXDTO.Status;
		СозданиеОрдераСтруктура.Комментарий = ОбменДаннымиWMS4.ОбработатьКомментарий(ОбъектXDTO.Description);
		
	КонецЕсли;
	
	СозданиеОрдераСтруктура.Ошибка = Ошибка;
	
КонецПроцедуры

// Создает структуру с полями для документа ордера в WMS.
//
// Возвращаемое значение:
//   Структура:
//     * ДокументОснования - ЛюбаяСсылка, Неопределено - документ-основание для ордера
//     * ДокументОснованияПроведен - Булево - признак того, что документ-основание проведен
//     * ДатаДокументаВWMS - Строка, Неопределено - дата документа в системе WMS
//     * НомерДокументаВWMS - Строка, Неопределено - номер документа в системе WMS
//     * СтатусДокументаВWMS - Строка, Неопределено - статус документа в системе WMS
//     * Комментарий - Строка - текст комментария к документу
//     * Результат - Булево - признак успешного выполнения операции
//     * Ошибка - Булево - признак наличия ошибки
//     * ТекстСообщения - Строка - текст сообщения об ошибке или информационного сообщения
Функция НовыйСозданиеОрдераСтруктура() Экспорт
	
	Структура = Новый Структура;
	Структура.Вставить("ДокументОснования", "");
	Структура.Вставить("ДокументОснованияПроведен", Истина);
	Структура.Вставить("ДатаДокументаВWMS", "");
	Структура.Вставить("НомерДокументаВWMS", "");
	Структура.Вставить("СтатусДокументаВWMS", "");
	Структура.Вставить("Комментарий", "");
	Структура.Вставить("Результат", Ложь);
	Структура.Вставить("Ошибка", Ложь);	
	Структура.Вставить("ТекстСообщения", "");
	
	Возврат Структура;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТипДокументаОснованияПоИсточникуПоступленияWMS(ИсточникПоступления)

	СоотвествиеИсточникПоступленияТипДокумента = Новый Соответствие();	
	СоотвествиеИсточникПоступленияТипДокумента.Вставить("Возврат от клиента", "ВозвратТоваровОтКлиента");
	СоотвествиеИсточникПоступленияТипДокумента.Вставить("Приемка от поставщика", "ЗаказПоставщику");
	СоотвествиеИсточникПоступленияТипДокумента.Вставить("Приемка со склада", "ПеремещениеТоваров");
	СоотвествиеИсточникПоступленияТипДокумента.Вставить("Приемка из производства", "СборкаТоваров");
	СоотвествиеИсточникПоступленияТипДокумента.Вставить("Поступление товаров от комиссионера", "ПоступлениеТоваровОтХранителя");
	//СоотвествиеТипДокументаИсточникПоступления.Вставить("Корректировка реализации", "КорректировкаРеализации");
	//СоотвествиеТипДокументаИсточникПоступления.Вставить("Оприходование товаров", "ОприходованиеИзлишковТоваров");
	
	Возврат СоотвествиеИсточникПоступленияТипДокумента[ИсточникПоступления];

КонецФункции

Функция ТипДокументаОснованияПоНаправлениюОтгрузкиWMS(НаправлениеОтгрузки)
	
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования = Новый Соответствие();
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Отгрузка клиенту", "РеализацияТоваровУслуг");
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Самовывоз", "РеализацияТоваровУслуг");
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Отгрузка на склад", "ПеремещениеТоваров");
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Отгрузка в производство", "СборкаТоваров");
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Возврат поставщику", "ВозвратТоваровПоставщику");
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Списание", "ВнутреннееПотребление");
	СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Передача товаров комиссионеру", "ПередачаТоваровХранителю");
	//СоотвествиеНаправлениеОтгрузкиТипДокументаОснования.Вставить("Корректировка реализации", "КорректировкаРеализации");
	
	Возврат СоотвествиеНаправлениеОтгрузкиТипДокументаОснования[НаправлениеОтгрузки];

КонецФункции

Функция СоответствиеСтатусовОжидаемойПриемкиПриходныхОрдеров(СтатусОжидаемаяПриемки)
	
	СоотвествиеСтатусов = Новый Соответствие;
	СоотвествиеСтатусов.Вставить("Не загружена", Перечисления.СтатусыПриходныхОрдеров.КПоступлению);
	СоотвествиеСтатусов.Вставить("Новая", Перечисления.СтатусыПриходныхОрдеров.КПоступлению);
	СоотвествиеСтатусов.Вставить("К выполнению", Перечисления.СтатусыПриходныхОрдеров.КПоступлению);
	СоотвествиеСтатусов.Вставить("В работе", Перечисления.СтатусыПриходныхОрдеров.ВРаботе);
	СоотвествиеСтатусов.Вставить("Промаркирована", Перечисления.СтатусыПриходныхОрдеров.Принят);
	СоотвествиеСтатусов.Вставить("Проконтролирована", Перечисления.СтатусыПриходныхОрдеров.ВРаботе);
	СоотвествиеСтатусов.Вставить("Заблокирована", Перечисления.СтатусыПриходныхОрдеров.ТребуетсяОбработка);
    	СоотвествиеСтатусов.Вставить("Принята", Перечисления.СтатусыПриходныхОрдеров.Принят);
	СоотвествиеСтатусов.Вставить("Завершена", Перечисления.СтатусыПриходныхОрдеров.Принят);	
	СоотвествиеСтатусов.Вставить("Размещена", Перечисления.СтатусыПриходныхОрдеров.Принят);	
	СоотвествиеСтатусов.Вставить("Отменена", "Отменена");
	
	Возврат СоотвествиеСтатусов[СтатусОжидаемаяПриемки];

КонецФункции

Функция СоответствиеСтатусовЗаказНаОтгрузкуРасходныхОрдеров(СтатусЗаказНаОтгрузку)
	
	СоотвествиеСтатусов = Новый Соответствие;
	СоотвествиеСтатусов.Вставить("Не загружен", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
	СоотвествиеСтатусов.Вставить("Новый", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
	СоотвествиеСтатусов.Вставить("К планированию", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
	СоотвествиеСтатусов.Вставить("Спланировано частично", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
	СоотвествиеСтатусов.Вставить("Спланирован", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
	СоотвествиеСтатусов.Вставить("В отбор", Перечисления.СтатусыРасходныхОрдеров.КОтбору);
	СоотвествиеСтатусов.Вставить("В отборе", Перечисления.СтатусыРасходныхОрдеров.КОтбору);
	СоотвествиеСтатусов.Вставить("Отобран", Перечисления.СтатусыРасходныхОрдеров.КПроверке);
	СоотвествиеСтатусов.Вставить("Упакован", Перечисления.СтатусыРасходныхОрдеров.КПроверке);	
	СоотвествиеСтатусов.Вставить("Готов к отгрузке", Перечисления.СтатусыРасходныхОрдеров.КОтгрузке);
	СоотвествиеСтатусов.Вставить("Отгружен", Перечисления.СтатусыРасходныхОрдеров.Отгружен);
	СоотвествиеСтатусов.Вставить("Заблокирован", Перечисления.СтатусыРасходныхОрдеров.КПроверке);
	СоотвествиеСтатусов.Вставить("Отменен", "Отменена");
	
	Возврат СоотвествиеСтатусов[СтатусЗаказНаОтгрузку];

КонецФункции

#КонецОбласти