Процедура ОбменДаннымиWMS4_СправочникиПередЗаписью(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
		
	Если ОбъектИзменен(Источник) Тогда 
		ВыборкаУзлов = ПланыОбмена.ОбменУправлениеТорговлейWMS4.Выбрать();
		Пока ВыборкаУзлов.Следующий() Цикл
			Если НЕ ВыборкаУзлов.Используется Тогда
				Продолжить;
			КонецЕсли;	
			Если ВыборкаУзлов.Ссылка <> ПланыОбмена.ОбменУправлениеТорговлейWMS4.ЭтотУзел() Тогда
				Источник.ОбменДанными.Получатели.Добавить(ВыборкаУзлов.Ссылка);
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

Процедура СправочникСкладыПриЗаписи(Источник, Отказ) Экспорт
	
	Перем Элемент;
	
	КлючАналитикиУчетаСкладовСтруктура
		= КлючАналитикиУчетаСкладовДляWMSСтруктураПоСкладу(Источник.Ссылка);		
		
	Если КлючАналитикиУчетаСкладовСтруктура.ЭтоНовый Тогда 
		Элемент = Справочники.ax_КлючАналитикиУчетаСкладовДляWMS.СоздатьЭлемент();	
	Иначе 
		Элемент = КлючАналитикиУчетаСкладовСтруктура.Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(
		Элемент, КлючАналитикиУчетаСкладовСтруктура,,"Ссылка, Код");
			
	Элемент.Записать();

КонецПроцедуры

Процедура ОбменДаннымиWMS4_ДокументыПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
		
	// Согласно бизнес-процессу, некоторые документы Перемещение товаров должны быть не проведены, но отправлены в работу в WMS
	// Для подобных ситуаций есть реквизит ОтправитьВУС (на форме это галочка Отправить в УС непроведенный)
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
		Если Не Источник.Проведен И РежимЗаписи <> РежимЗаписиДокумента.Проведение И НЕ Источник.ax_ОтправитьВУСНепроведенным Тогда
			Возврат; 
		КонецЕсли;	
	Иначе		
		Если Не Источник.Проведен И РежимЗаписи <> РежимЗаписиДокумента.Проведение Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ Источник.ax_УС Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
		Если Источник.СкладОтправитель = Источник.СкладПолучатель Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПередачаТоваровХранителю")  Тогда
		
		Если Источник.ХозяйственнаяОперация <> Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПоступлениеТоваровОтХранителя") Тогда
		
		Если Источник.ХозяйственнаяОперация <> Перечисления.ХозяйственныеОперации.ВозвратОтКомиссионера Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	// РеализацияТоваровУслуг,
	// ЗаказПоставщику,
	// ОприходованиеТоваров,
	// СписаниеТоваров,
	// КорректировкаРеализации,
	// КомплектацияНоменклатуры
	Если ОбъектИзменен(Источник) Тогда 	
		ВыборкаУзлов = ПланыОбмена.ОбменУправлениеТорговлейWMS4.Выбрать();
		
		МассивСклад = Новый Массив;
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
			МассивСклад.Добавить(Источник.СкладОтправитель);
			МассивСклад.Добавить(Источник.СкладПолучатель);
			МассивСклад.Добавить(Источник.Ссылка.СкладОтправитель);
			МассивСклад.Добавить(Источник.Ссылка.СкладПолучатель);
		Иначе
			МассивСклад.Добавить(Источник.Склад);
			МассивСклад.Добавить(Источник.Ссылка.Склад);
		КонецЕсли;  
		
		Пока ВыборкаУзлов.Следующий() Цикл
			Если ВыборкаУзлов.Ссылка <> ПланыОбмена.ОбменУправлениеТорговлейWMS4.ЭтотУзел() Тогда
				
				Если НЕ ВыборкаУзлов.Используется Тогда
					Продолжить;
				КонецЕсли;	
				
				ФильтрСкладИДата = Ложь;
				
				Индекс = МассивСклад.ВГраница();
				
				Пока Индекс >= 0 И НЕ ФильтрСкладИДата Цикл 
					СтрокаТЧ = ВыборкаУзлов.Склады.Найти(МассивСклад[Индекс]);
					Если СтрокаТЧ <> Неопределено Тогда
						Если Источник.Дата >= СтрокаТЧ.ДатаНачалаВыгрузкиДокументов Тогда
							ФильтрСкладИДата = Истина;
						КонецЕсли;
					КонецЕсли;
					Индекс = Индекс - 1;
				КонецЦикла;	
				
				Если ФильтрСкладИДата Тогда
					Источник.ОбменДанными.Получатели.Добавить(ВыборкаУзлов.Ссылка);
				КонецЕсли;
				
			КонецЕсли;	
		КонецЦикла;	
		
	КонецЕсли;
	
КонецПроцедуры

