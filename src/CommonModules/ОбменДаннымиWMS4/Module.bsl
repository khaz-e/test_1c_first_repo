Функция СоздатьСтруктуруГруппНоменклатуры(Номенклатура, Узел)
	
	Родитель = Номенклатура.Родитель;
	мсвГруппы = Новый Массив();
	Пока НЕ Родитель.Пустая() Цикл
		мсвГруппы.Вставить(0, Родитель.Ссылка);
		Родитель = Родитель.Родитель;
	КонецЦикла;	
	
	Для Каждого ГруппаТоваров Из мсвГруппы Цикл
		СоздатьГруппуНоменклатуры(ГруппаТоваров, Узел);
	КонецЦикла;	
	
КонецФункции

Функция СоздатьГруппуНоменклатуры(Родитель, Узел)
	
	// Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;
	
	// Группа номенклатуры
	НоменклатураТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package","axNomenclature");
	
	СтруктураНоменклатура = Новый Структура();
	СтруктураНоменклатура.Вставить("ID",Строка(Родитель.УникальныйИдентификатор()));
	СтруктураНоменклатура.Вставить("IsGroup",Родитель.ЭтоГруппа);
	СтруктураНоменклатура.Вставить("GroupID",Строка(Родитель.Родитель.УникальныйИдентификатор()));
	СтруктураНоменклатура.Вставить("Name",Строка(Родитель.Наименование));
	СтруктураНоменклатура.Вставить("Code",Строка(Родитель.Код));
	СтруктураНоменклатура.Вставить("CodeCIS",Строка(Родитель.Код));
	
	ОбъектXDTO      = Фабрика.Создать(НоменклатураТип);
	
	ЗаполнитьЗначенияСвойств(ОбъектXDTO, СтруктураНоменклатура, "ID, IsGroup, GroupID, Name, Code, CodeCIS");

	РезультатОперации = Прокси.SetNomenclature(ОбъектXDTO, Узел.Идентификатор);
	
	Возврат РезультатОперации;
	
КонецФункции	

Функция ВыгрузитьШтрихкоды(Номенклатура, Узел)
	
	РезультатОперации = Истина;
	
	// Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;
	
	// Штрихкод из регистра НоменклатураКонтрагентов
	ШтрикодТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package","axBarcodeLine");
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НоменклатураКонтрагентов.Штрихкод КАК Штрихкод,
	|	НоменклатураКонтрагентов.Владелец КАК Контрагент
	|ПОМЕСТИТЬ табШтрихкодКонтрагент
	|ИЗ
	|	Справочник.НоменклатураКонтрагентов КАК НоменклатураКонтрагентов
	|ГДЕ
	|	НоменклатураКонтрагентов.Номенклатура = &Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	табШтрихкодКонтрагент.Штрихкод,
	|	ДополнительныеСведения.Значение КАК Склад
	|ИЗ
	|	табШтрихкодКонтрагент КАК табШтрихкодКонтрагент
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО (табШтрихкодКонтрагент.Контрагент = ДополнительныеСведения.Объект
	|				И ДополнительныеСведения.Свойство.Наименование = ""Склад"")";
	
