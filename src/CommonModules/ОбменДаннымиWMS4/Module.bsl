// Проверяет одинаковость двух массивов с элементами ссылочных типов
//
// Параметры:
//  Массив1 - массив ссылок
//  Массив2 - массив ссылок
//
// Возвращаемое значение:
//  Истина если массивы - одинаковы
Функция МассивыСсылочныхТиповРазные(Массив1, Массив2)
	
	Строка1 = "";
	Для каждого элемент Из Массив1 Цикл
		Строка1  = Строка1 + Элемент.УникальныйИдентификатор();		
	КонецЦикла;

	Строка2 = "";
	Для каждого элемент Из Массив2 Цикл
		Строка2  = Строка2 + Элемент.УникальныйИдентификатор();		
	КонецЦикла;
	
	Возврат Строка1 <> Строка2
	
КонецФункции

// Функция возвращает комментарий в многострочном виде
// Каждая строка начинается с символа "> "
// Убираются неуникальные подкомментарии
// Подкомментарии сортируются по дате
//
// КомментДляРедактирования - Строка с разделителем ">"
// если разбор будет неудачным, то возвратит то что было подано на вход
Функция ОбработатьКомментарий(КомментДляРедактирования) Экспорт
	
	МассивКомментов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КомментДляРедактирования,">");
	
	ТЗдляСортировкиКомментовПоДате = Новый ТаблицаЗначений;
	ТЗдляСортировкиКомментовПоДате.Колонки.Добавить("ДатаВремя");
	ТЗдляСортировкиКомментовПоДате.Колонки.Добавить("Коммент");
	
	Для Каждого Коммент Из МассивКомментов Цикл 
		
		СтрокаКоммент = СокрЛП(Коммент);
		
		// Проверим заполнен ли подкомментарий и есть ли он в ТЗ
		Если ЗначениеЗаполнено(СтрокаКоммент) И ТЗдляСортировкиКомментовПоДате.Найти(СтрокаКоммент,"Коммент") = Неопределено Тогда 
			
			ДатаВКомменте = Лев(СтрокаКоммент,19);  // Выделим из подстроки дату 
			
			Если Прав(ДатаВКомменте,1) = "," Тогда
				ДатаВКомменте = Лев(СтрокаКоммент,18);
			КонецЕсли;
			
			// могут быть комментарии которые уже были до ввода новых правил (с вводом разделителя и даты на обоих сторонах обмена)
			// поэтому отсечем ситуации когда Дата("фыждаложфыла") вываливается в ошибку
			Попытка
				ДатаВКомменте = Дата(ДатаВКомменте);
			Исключение  
				Возврат КомментДляРедактирования;
			КонецПопытки;
			
			СтрокаТЗ = ТЗдляСортировкиКомментовПоДате.Добавить();
			СтрокаТЗ.ДатаВремя = ДатаВКомменте;
			СтрокаТЗ.Коммент   = СтрокаКоммент;
			
		КонецЕсли;
	КонецЦикла;
	
	// Отсортируем комментарии по дате
	ТЗдляСортировкиКомментовПоДате.Сортировать("ДатаВремя");
	
	Коммент = "";
	
	Для Каждого СтрокаТЗ Из ТЗдляСортировкиКомментовПоДате Цикл 
		
		РедактирКоммент = "> " + СтрокаТЗ.Коммент; 
		Коммент = Коммент + РедактирКоммент + Символы.ПС;
	КонецЦикла;	
	
	Возврат Коммент;
	
КонецФункции

