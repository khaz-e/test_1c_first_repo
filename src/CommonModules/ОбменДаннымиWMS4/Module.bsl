			СтруктураТовары.Вставить("QualityID",ПолучитьIDГрадацииКачества(СтрокаТовары.Номенклатура.Качество));
			
			Если Узел.ВыгружатьПартии Тогда
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[ДокументОбъект.Склад].Код;
				
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаТовары.Номенклатура.Код)));	
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка", ДокументОбъект.Ссылка);
			
			ТЧXDTO = Фабрика.Создать(СтрокаЗаказНаОтгрузкуТип);
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Добавить(ТЧXDTO);
		КонецЦикла;
		
		РезультатОперации = Прокси.SetShippingPlan(ОбъектXDTO_ЗаказНаОтгрузку, Узел.Идентификатор);
		
		Возврат РезультатОперации;
		
		Возврат Ложь;
		
	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине:
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, ДокументОбъект.Метаданные(), ДокументОбъект.Ссылка);
		
		Возврат Ложь;
		
	КонецПопытки;
	
КонецФункции

Функция ВыгрузитьВнутреннееПотребление_ЗаказНаОтгрузку(ВнутреннееПотреблениеОбъект, Узел)
	
	ЗначенияРеквизитовСкладов = ЗначенияРеквизитовСкладов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВнутреннееПотреблениеОбъект.Склад),
		"Ссылка, Наименование");
	
	Попытка
		
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль = Узел.Пароль;
		
		Фабрика = Прокси.ФабрикаXDTO;
		
		// Организация
		ВыгрузитьОрганизацию(ВнутреннееПотреблениеОбъект.Организация, Узел);
		
		// Контрагент
		КонтрагентСсылка = Справочники.Контрагенты.НайтиПоНаименованию("Списание товаров");
		ВыгрузитьПокупателя(КонтрагентСсылка, Узел);
				
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID", Строка(ВнутреннееПотреблениеОбъект.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Date", ВнутреннееПотреблениеОбъект.Дата);
		СтруктураДокумента.Вставить("Number", "ВН" + Прав(ВнутреннееПотреблениеОбъект.Номер, СтрДлина(ВнутреннееПотреблениеОбъект.Номер)-2));
		СтруктураДокумента.Вставить("ShipmentDirection", "Списание");
		СтруктураДокумента.Вставить("Priority", "Обычная");
		СтруктураДокумента.Вставить("ExpectedDate", ВнутреннееПотреблениеОбъект.Дата);
		СтруктураДокумента.Вставить("CounterpartyID", Строка(КонтрагентСсылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("OrganizationID", Строка(ВнутреннееПотреблениеОбъект.Организация.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Description", ВнутреннееПотреблениеОбъект.Комментарий);
		СтруктураДокумента.Вставить("Ссылка", ВнутреннееПотреблениеОбъект);
		СтруктураДокумента.Вставить("ContractDate", Дата("00010101"));
		СтруктураДокумента.Вставить("ContractNumber","");
		СтруктураДокумента.Вставить("IsMarked", ВнутреннееПотреблениеОбъект.ПометкаУдаления);
		
		ОбъектXDTO_ЗаказНаОтгрузку = Фабрика.Создать(Фабрика
			.Тип("http://www.axelot.ru/tms2_exchange/package", "axShippingPlan"));
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_ЗаказНаОтгрузку, СтруктураДокумента);    
		
		// Поклажедатель / склад
		Если Узел.ВыгружатьПоклажедателя Тогда
			
			ОбъектXDTO_ДополнительныеРеквизиты = Фабрика.Создать(Фабрика
				.Тип("http://www.axelot.ru/tms2_exchange/package", "axComplementaryElements"));
			ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "Поклажедатель";
			ОбъектXDTO_ДополнительныеРеквизиты.Value = СокрЛП(ВнутреннееПотреблениеОбъект.Склад);
			
			ОбъектXDTO_ЗаказНаОтгрузку.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
			
		КонецЕсли;	
		
		Для Каждого СтрокаТовары Из ВнутреннееПотреблениеОбъект.Товары Цикл
			
			Если СтрокаТовары.Номенклатура.ВидНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда 
				Продолжить;
			КонецЕсли;
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаТовары.Номенклатура, Узел);
			
			// Единица
			Единица = ?(СтрокаТовары.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
						СтрокаТовары.Упаковка,
						СтрокаТовары.Номенклатура.ЕдиницаИзмерения
						);
			ВыгрузитьЕдиницу(Единица, Узел);
			
			// Качество
			ВыгрузитьКачество(СтрокаТовары.Номенклатура.Качество, Узел);
			
			// Партия
			//ВыгрузитьПартию(ВнутреннееПотреблениеОбъект.Склад, СтрокаТовары.Номенклатура, Узел);
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[ВнутреннееПотреблениеОбъект.Склад], 
				СтрокаТовары.Номенклатура, Узел);
			
			
			// Строки документа "Заказ на отгрузку"
			СтруктураТовары = Новый Структура();
			СтруктураТовары.Вставить("NomenclatureID", Строка(СтрокаТовары.Номенклатура.УникальныйИдентификатор()));
			СтруктураТовары.Вставить("StorangeUnitID", Строка(Единица.УникальныйИдентификатор()));
			
			// StorangeUnitID -- как я понял, это упаковка потому указал именно упаковку
			// я попробывал базовую единицу измерения, но он все равно отрабатывает без ошибки
			// пока оставлю как упаковку
			//СтруктураТовары.Вставить("StorangeUnitID",Строка(Единица.УникальныйИдентификатор()));
			
			СтруктураТовары.Вставить("TaxRate", "БезНДС");
			СтруктураТовары.Вставить("Amount", 0);
			
			// Количество план = 0, если документ помечен на удаление
			КоличествоПлан = ?(ВнутреннееПотреблениеОбъект.ПометкаУдаления, 0, СтрокаТовары.Количество);
			СтруктураТовары.Вставить("Quantity", КоличествоПлан);
			СтруктураТовары.Вставить("QuantityUnit", КоличествоПлан);
			СтруктураТовары.Вставить("LineNum", СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(СтрокаТовары.ax_КодСтроки), 10, "0", "Слева"));
			
			// В УТ 10 качество это справочник
			//СтруктураТовары.Вставить("QualityID",Строка(СтрокаРеализация.Номенклатура.Качество.УникальныйИдентификатор()));
			
			// В УТ 11 качество задается перечислением ГрадацииКачества
			// Уникальный идентификатор у перечисления можно получить через запрос
			// Создана функция ПолучитьIDГрадацииКачества()
			СтруктураТовары.Вставить("QualityID", ПолучитьIDГрадацииКачества(СтрокаТовары.Номенклатура.Качество));
			
			// в коде ВМС нет создания соответствия идентификатора элементу справочника качества
			// похоже он создавался вручную
			// решили заменить в регистре усИдентификаторыОбмена - "Идентификаторы обмена (web-сервис)"
			// Кондиция		d05404a0-6bce-449b-a798-41ebe5e5b977 (этот идентификатор использовался в УТ 10)
			// на 
			// Кондиция		b21b212c-ce0e-477b-be8e-0fc91014bfea (этот идентификатор возвращает ПолучитьIDГрадацииКачества в УТ 11)
			
			Если Узел.ВыгружатьПартии Тогда
				
				//СтруктураТовары.Вставить("ConsignmentID", 
				//	Строка(ВнутреннееПотреблениеОбъект.Склад.УникальныйИдентификатор()) + "_" + Строка(СтрокаТовары.Номенклатура.Код));
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[ВнутреннееПотреблениеОбъект.Склад].Код;
				
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаТовары.Номенклатура.Код)));
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка", ВнутреннееПотреблениеОбъект);
			
			ТЧXDTO = Фабрика.Создать(Фабрика
				.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine"));
				
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Добавить(ТЧXDTO);
			
		КонецЦикла;
	
		Возврат Прокси.SetShippingPlan(ОбъектXDTO_ЗаказНаОтгрузку, Узел.Идентификатор);

	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));		
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, ВнутреннееПотреблениеОбъект.Метаданные(), ВнутреннееПотреблениеОбъект.Ссылка);		
			
		Возврат Ложь;	

	КонецПопытки;
		
КонецФункции

Функция Выгрузить_ВозвратТоваровПоставщику_ЗаказНаОтгрузку(ВозвратТоваровПоставщикуОбъект, Узел)
	
	ЗначенияРеквизитовСкладов = ЗначенияРеквизитовСкладов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВозвратТоваровПоставщикуОбъект.Склад),
		"Ссылка, Наименование");
	
	Попытка
		
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль = Узел.Пароль;
		
		Фабрика = Прокси.ФабрикаXDTO;
		
		// Организация
		ВыгрузитьОрганизацию(ВозвратТоваровПоставщикуОбъект.Организация, Узел);
		
		// Покупатель
		ВыгрузитьПокупателя(ВозвратТоваровПоставщикуОбъект.Контрагент, Узел);
		
		// Заказ на отгрузку
		ЗаказНаОтгрузкуТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axShippingPlan");
		СтрокаЗаказНаОтгрузкуТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
		
		// Доп. реквизиты. Поклажедатель (склад)
		ДополнительныеРеквизитыТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axComplementaryElements");
		
		
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID", Строка(ВозвратТоваровПоставщикуОбъект.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Date",ВозвратТоваровПоставщикуОбъект.Дата);
		СтруктураДокумента.Вставить("Number","ВП" + Прав(ВозвратТоваровПоставщикуОбъект.Номер, СтрДлина(ВозвратТоваровПоставщикуОбъект.Номер)-2));
		СтруктураДокумента.Вставить("ShipmentDirection", "Возврат поставщику");
		СтруктураДокумента.Вставить("Priority","Обычная");
		СтруктураДокумента.Вставить("ExpectedDate", ВозвратТоваровПоставщикуОбъект.Дата);
		СтруктураДокумента.Вставить("CounterpartyID",Строка(ВозвратТоваровПоставщикуОбъект.Контрагент.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("OrganizationID",Строка(ВозвратТоваровПоставщикуОбъект.Организация.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Description", ВозвратТоваровПоставщикуОбъект.Комментарий);
		СтруктураДокумента.Вставить("Ссылка", ВозвратТоваровПоставщикуОбъект.Ссылка);
		СтруктураДокумента.Вставить("DeliveryAddress", ВозвратТоваровПоставщикуОбъект.АдресДоставки);
		СтруктураДокумента.Вставить("DeliveryComment", ВозвратТоваровПоставщикуОбъект.АдресДоставки);
		СтруктураДокумента.Вставить("ContractDate", Дата("00010101"));
		СтруктураДокумента.Вставить("ContractNumber", "");
		СтруктураДокумента.Вставить("IsMarked", ВозвратТоваровПоставщикуОбъект.ПометкаУдаления);
			
		ОбъектXDTO_ВозвратТоваровПоставщику = Фабрика.Создать(ЗаказНаОтгрузкуТип);
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_ВозвратТоваровПоставщику, СтруктураДокумента);    
		
		// Поклажедатель / склад
		Если Узел.ВыгружатьПоклажедателя Тогда
			
			ОбъектXDTO_ДополнительныеРеквизиты = Фабрика.Создать(ДополнительныеРеквизитыТип);
			ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "Поклажедатель";
			ОбъектXDTO_ДополнительныеРеквизиты.Value = СокрЛП(Строка(ВозвратТоваровПоставщикуОбъект.Склад));
			
			ОбъектXDTO_ВозвратТоваровПоставщику.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
			
		КонецЕсли;	
		
		// При значении "Возврат поставщику" направлении отгрузки, документ заказ на отгрузку требудет обязательное заполнение
		// документа основания, в качестве которого используется документ ожидаемая примка. В документ ожидаемая приемка
		// выгружается заказ поставщику, УИД которого необходимо передать.
		//Пока ничего кроме дополнительного реквизита не придумал, для обработки которого на стороне
		// WMS написал функцию
		
		ЗаказПоставщикуСтруктура = ЗаказПоставщикуПоДокументуВозврата(ВозвратТоваровПоставщикуОбъект.Ссылка);
		
		Если ЗаказПоставщикуСтруктура.Ошибка Тогда 
			ВызватьИсключение ЗаказПоставщикуСтруктура.ОписаниеОшибки;
		Иначе 
			ОбъектXDTO_ДополнительныеРеквизиты = Фабрика.Создать(ДополнительныеРеквизитыТип);
			ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "ДокументОснованияВозвратаПоставщику";
			ОбъектXDTO_ДополнительныеРеквизиты.Value = ЗаказПоставщикуСтруктура.ЗаказПоставщикуУИД;		
			ОбъектXDTO_ВозвратТоваровПоставщику.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
		КонецЕсли;
			
		Для Каждого СтрокаТовары Из ВозвратТоваровПоставщикуОбъект.Товары Цикл
			
			Если СтрокаТовары.Номенклатура.ВидНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда 
				Продолжить;
			КонецЕсли;
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаТовары.Номенклатура,Узел);
			
			// Единица
			Единица = ?(СтрокаТовары.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
						СтрокаТовары.Упаковка, СтрокаТовары.Номенклатура.ЕдиницаИзмерения);
			ВыгрузитьЕдиницу(Единица, Узел);
			
			// Качество
			ВыгрузитьКачество(СтрокаТовары.Номенклатура.Качество, Узел);
			
			// Партия
			//ПартияСоздана = ВыгрузитьПартию(ВозвратТоваровПоставщикуОбъект.Склад, СтрокаТовары.Номенклатура, Узел);
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[ВозвратТоваровПоставщикуОбъект.Склад],
				СтрокаТовары.Номенклатура, Узел);
			
			
			// Строки документа "Заказ на отгрузку"
			СтруктураТовары = Новый Структура();
			СтруктураТовары.Вставить("NomenclatureID", Строка(СтрокаТовары.Номенклатура.УникальныйИдентификатор()));
			СтруктураТовары.Вставить("StorangeUnitID", Строка(Единица.УникальныйИдентификатор()));
			
			// StorangeUnitID -- как я понял, это упаковка потому указал именно упаковку
			// я попробывал базовую единицу измерения, но он все равно отрабатывает без ошибки
			// пока оставлю как упаковку
			//СтруктураТовары.Вставить("StorangeUnitID", Строка(Единица.УникальныйИдентификатор()));
			
			СтруктураТовары.Вставить("TaxRate","БезНДС");
			СтруктураТовары.Вставить("Amount",СтрокаТовары.Цена);
			
			// Количество план = 0, если документ помечен на удаление
			КоличествоПлан = ?(ВозвратТоваровПоставщикуОбъект.ПометкаУдаления, 0, СтрокаТовары.Количество);
			СтруктураТовары.Вставить("Quantity", КоличествоПлан);
			СтруктураТовары.Вставить("QuantityUnit", КоличествоПлан);
			СтруктураТовары.Вставить("LineNum", СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(СтрокаТовары.ax_КодСтроки), 10, "0", "Слева"));
			
			// В УТ 11 качество задается перечислением ГрадацииКачества
			// Уникальный идентификатор у перечисления можно получить через запрос
			// Создана функция ПолучитьIDГрадацииКачества()
			СтруктураТовары.Вставить("QualityID", ПолучитьIDГрадацииКачества(СтрокаТовары.Номенклатура.Качество));
			
			Если Узел.ВыгружатьПартии Тогда
				
				//СтруктураТовары.Вставить("ConsignmentID", Строка(ВозвратТоваровПоставщикуОбъект.Склад.Код) + "_" + Строка(СтрокаТовары.Номенклатура.Код));
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[ВозвратТоваровПоставщикуОбъект.Склад].Код;
				
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаТовары.Номенклатура.Код)));
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка", ВозвратТоваровПоставщикуОбъект);
			
			ТЧXDTO = Фабрика.Создать(СтрокаЗаказНаОтгрузкуТип);
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_ВозвратТоваровПоставщику.GoodsLine.Добавить(ТЧXDTO);
		КонецЦикла;
		
		РезультатОперации = Прокси.SetShippingPlan(ОбъектXDTO_ВозвратТоваровПоставщику, Узел.Идентификатор);		
		Возврат РезультатОперации;
		
	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине:
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, ВозвратТоваровПоставщикуОбъект.Метаданные(), ВозвратТоваровПоставщикуОбъект.Ссылка);
		Возврат Ложь;
		
	КонецПопытки;
	
КонецФункции

Функция ВыгрузитьСписаниеТоваров_ЗаказНаОтгрузку(СписаниеТоваров, Узел)
	
	ЗначенияРеквизитовСкладов = ЗначенияРеквизитовСкладов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СписаниеТоваров.Склад),
		"Ссылка, Наименование");
	
	Попытка
	
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль       = Узел.Пароль;
		
		Фабрика = Прокси.ФабрикаXDTO;
		
		// Организация
		ВыгрузитьОрганизацию(СписаниеТоваров.Организация,Узел);
		
		// Контрагент
		КонтрагентСсылка = Справочники.Контрагенты.НайтиПоНаименованию("Списание товаров");
		ВыгрузитьПокупателя(КонтрагентСсылка, Узел);
		
		// Склад
		// ВыгрузитьСклад(СписаниеТоваров.Склад, Узел);
		
		// Заказ на отгрузку
		ЗаказНаОтгрузкуТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axShippingPlan");
		СтрокаЗаказНаОтгрузкуТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
		
		// Доп. реквизиты. Поклажедатель (склад)
		ДополнительныеРеквизитыТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axComplementaryElements");
				
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID",Строка(СписаниеТоваров.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Date",СписаниеТоваров.Дата);
		СтруктураДокумента.Вставить("Number","СП" + Прав(СписаниеТоваров.Номер, СтрДлина(СписаниеТоваров.Номер)-2));
		СтруктураДокумента.Вставить("ShipmentDirection","Списание");
		СтруктураДокумента.Вставить("Priority","Обычная");
		СтруктураДокумента.Вставить("ExpectedDate",СписаниеТоваров.Дата);
		СтруктураДокумента.Вставить("CounterpartyID",Строка(КонтрагентСсылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("OrganizationID",Строка(СписаниеТоваров.Организация.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Description",СписаниеТоваров.Комментарий);
		СтруктураДокумента.Вставить("Ссылка",СписаниеТоваров);
		СтруктураДокумента.Вставить("ContractDate",Дата("00010101"));
		СтруктураДокумента.Вставить("ContractNumber","");
		СтруктураДокумента.Вставить("IsMarked",СписаниеТоваров.ПометкаУдаления);	
		
		ОбъектXDTO_ЗаказНаОтгрузку          = Фабрика.Создать(ЗаказНаОтгрузкуТип);
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_ЗаказНаОтгрузку, СтруктураДокумента);
		
		// Поклажедатель / склад
		Если Узел.ВыгружатьПоклажедателя Тогда
			
			ОбъектXDTO_ДополнительныеРеквизиты = Фабрика.Создать(ДополнительныеРеквизитыТип);
			ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "Поклажедатель";
			ОбъектXDTO_ДополнительныеРеквизиты.Value = СокрЛП(СписаниеТоваров.Склад);
			
			ОбъектXDTO_ЗаказНаОтгрузку.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
			
		КонецЕсли;	
		
		Для Каждого СтрокаСписаниеТоваров Из СписаниеТоваров.Товары Цикл
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаСписаниеТоваров.Номенклатура,Узел);
			
			// Единица
			Единица = СтрокаСписаниеТоваров.Номенклатура.ЕдиницаИзмерения;
			ВыгрузитьЕдиницу(Единица, Узел);
			
			// Качество
			ВыгрузитьКачество(СтрокаСписаниеТоваров.Номенклатура.Качество, Узел);
			
			// Партия
			//ПартияСоздана = ВыгрузитьПартию(СписаниеТоваров.Склад, СтрокаСписаниеТоваров.Номенклатура, Узел);
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[СписаниеТоваров.Склад], 
				СтрокаСписаниеТоваров.Номенклатура, Узел);
						
			// Строки документа "Заказ на отгрузку"
			СтруктураТовары = Новый Структура();
			СтруктураТовары.Вставить("NomenclatureID", Строка(СтрокаСписаниеТоваров.Номенклатура.УникальныйИдентификатор()));
			СтруктураТовары.Вставить("StorangeUnitID", Строка(Единица.УникальныйИдентификатор()));
			СтруктураТовары.Вставить("TaxRate", "БезНДС");
			
			//СтруктураТовары.Вставить("Amount",СтрокаСписаниеТоваров.Цена);
			СтруктураТовары.Вставить("Amount", 0); // нет поля в табличной части (пока не знаю как это будет организовано)
			
			
			// Количество план = 0, если документ помечен на удаление
			КоличествоПлан = ?(СписаниеТоваров.ПометкаУдаления, 0, СтрокаСписаниеТоваров.Количество);
			СтруктураТовары.Вставить("Quantity",КоличествоПлан);
			СтруктураТовары.Вставить("QuantityUnit",КоличествоПлан);
			
			СтруктураТовары.Вставить("LineNum", СтрокаСписаниеТоваров.ax_КодСтроки);
			СтруктураТовары.Вставить("QualityID",ПолучитьIDГрадацииКачества(СтрокаСписаниеТоваров.Номенклатура.Качество));
			//СтруктураТовары.Вставить("QualityID",Строка(СтрокаСписаниеТоваров.Качество.УникальныйИдентификатор()));
			
			Если Узел.ВыгружатьПартии Тогда
				
				//СтруктураТовары.Вставить(
				//	"ConsignmentID",
				//	Строка(СписаниеТоваров.Склад.УникальныйИдентификатор()) + "_" + Строка(СтрокаСписаниеТоваров.Номенклатура.Код)
				//);
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[СписаниеТоваров.Склад].Код;
				
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаСписаниеТоваров.Номенклатура.Код)));
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка",СписаниеТоваров);
			
			ТЧXDTO = Фабрика.Создать(СтрокаЗаказНаОтгрузкуТип);
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Добавить(ТЧXDTO);
		КонецЦикла;
		
		Если ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Количество() > 0 Тогда
			РезультатОперации = Прокси.SetShippingPlan(ОбъектXDTO_ЗаказНаОтгрузку, Узел.Идентификатор);
	    	Иначе
			РезультатОперации = Истина;
		КонецЕсли;
		
		Возврат РезультатОперации;
		
	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине:
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, СписаниеТоваров.Метаданные(), СписаниеТоваров.Ссылка);
		
		Возврат Ложь;
		
	КонецПопытки;
	
КонецФункции	

