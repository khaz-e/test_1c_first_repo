Функция КлючАналитикиУчетаСкладовДляWMSСтруктураПоСкладу(СкладСсылка)
	
	Структура = Новый Структура(
		"ЭтоНовый, Ссылка, Код, СкладУТ, РодительУТ, ЭтоГруппаУТ, Наименование", Ложь);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ЕСТЬNULL(КлючАналитикиУчетаСкладов.Ссылка, """") КАК Ссылка,
	|	ЕСТЬNULL(КлючАналитикиУчетаСкладов.Код, """") КАК Код,
	|	ВЫБОР
	|		КОГДА КлючАналитикиУчетаСкладов.Ссылка ЕСТЬ NULL
	|			ТОГДА Склады.Ссылка
	|		ИНАЧЕ КлючАналитикиУчетаСкладов.СкладУТ
	|	КОНЕЦ КАК СкладУТ,
	|	ВЫБОР
	|		КОГДА КлючАналитикиУчетаСкладов.Ссылка ЕСТЬ NULL
	|			ТОГДА Склады.Родитель
	|		ИНАЧЕ КлючАналитикиУчетаСкладов.РодительУТ
	|	КОНЕЦ КАК РодительУТ,
	|	ВЫБОР
	|		КОГДА КлючАналитикиУчетаСкладов.Ссылка ЕСТЬ NULL
	|			ТОГДА Склады.ЭтоГруппа
	|		ИНАЧЕ КлючАналитикиУчетаСкладов.ЭтоГруппаУТ
	|	КОНЕЦ КАК ЭтоГруппаУТ,
	|	ВЫБОР
	|		КОГДА КлючАналитикиУчетаСкладов.Ссылка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоНовый,
	|	ВЫБОР
	|		КОГДА КлючАналитикиУчетаСкладов.Ссылка ЕСТЬ NULL
	|			ТОГДА Склады.Наименование
	|		ИНАЧЕ КлючАналитикиУчетаСкладов.Наименование
	|	КОНЕЦ КАК Наименование
	|ИЗ
	|	Справочник.Склады КАК Склады
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ax_КлючАналитикиУчетаСкладовДляWMS КАК КлючАналитикиУчетаСкладов
	|		ПО (Склады.Ссылка = КлючАналитикиУчетаСкладов.СкладУТ)
	|ГДЕ
	|	Склады.Ссылка = &Склад");
	
	Запрос.УстановитьПараметр("Склад", СкладСсылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		ЗаполнитьЗначенияСвойств(Структура, Выборка);		
	КонецЕсли;
	
	Возврат Структура;
	
КонецФункции

Функция ЗначенияРеквизитовСкладов(Склады, Знач Реквизиты)
	
	ЗначенияРеквизитовОбъектов = ОбщегоНазначения
		.ЗначенияРеквизитовОбъектов(Склады, "Ссылка, Наименование");
	
	
	Для Каждого ЭлементСсылка Из Склады Цикл
		
		КлючАналитикиУчетаСкладов = КлючАналитикиУчетаСкладовДляWMSСтруктураПоСкладу(ЭлементСсылка);
		
		ЗначениеРеквизитовОбъекта = ЗначенияРеквизитовОбъектов[ЭлементСсылка];
		ЗначениеРеквизитовОбъекта.Вставить("Код", КлючАналитикиУчетаСкладов.Код);
	
	КонецЦикла;
	
	Возврат ЗначенияРеквизитовОбъектов;

КонецФункции

Процедура ВыполнитьПеремещениеВнутриОдногоУзла(ПеремещениеТоваровСсылка, Результат) Экспорт
	
	Запрос = Новый Запрос("ВЫБРАТЬ
		|	ПеремещениеТоваров.Ссылка КАК ПеремещениеТоваровСсылка,
		|	ПеремещениеТоваров.Проведен КАК Проведен,
		|	ПеремещениеТоваров.Номер КАК Номер,
		|	ПеремещениеТоваров.Дата КАК Дата,
		|	ПеремещениеТоваров.Комментарий КАК Комментарий,
		|	ПеремещениеТоваров.СкладОтправитель КАК СкладОтправитель,
		|	ПеремещениеТоваров.СкладПолучатель КАК СкладПолучатель
		|ПОМЕСТИТЬ втПеремещениеТоваров
		|ИЗ
		|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
		|ГДЕ
		|	ПеремещениеТоваров.Ссылка = &ПеремещениеТоваровСсылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПланОбменаСклады.Ссылка КАК ПланОбменаСсылка,
		|	ПланОбменаСклады.Склад КАК Склад
		|ПОМЕСТИТЬ втПланОбменаСклады
		|ИЗ
		|	ПланОбмена.ОбменУправлениеТорговлейWMS4.Склады КАК ПланОбменаСклады
		|ГДЕ
		|	НЕ ПланОбменаСклады.Ссылка.ПометкаУдаления
		|	И НЕ ПланОбменаСклады.Ссылка.ЭтотУзел
		|	И ПланОбменаСклады.Ссылка.Используется
		|	И ПланОбменаСклады.Склад В
		|			(ВЫБРАТЬ
		|				втПеремещениеТоваров.СкладОтправитель КАК Склад
		|			ИЗ
		|				втПеремещениеТоваров КАК втПеремещениеТоваров
		|		
		|			ОБЪЕДИНИТЬ ВСЕ
		|		
		|			ВЫБРАТЬ
		|				втПеремещениеТоваров.СкладПолучатель
		|			ИЗ
		|				втПеремещениеТоваров КАК втПеремещениеТоваров)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втПеремещениеТоваров.ПеремещениеТоваровСсылка КАК ПеремещениеТоваровСсылка,
		|	втПланОбменаСклады.ПланОбменаСсылка КАК УзелОтправитель,
		|	NULL КАК УзелПолучатель
		|ПОМЕСТИТЬ втОбъеденить
		|ИЗ
		|	втПеремещениеТоваров КАК втПеремещениеТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втПланОбменаСклады КАК втПланОбменаСклады
		|		ПО втПеремещениеТоваров.СкладОтправитель = втПланОбменаСклады.Склад
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	втПеремещениеТоваров.ПеремещениеТоваровСсылка,
		|	NULL,
		|	втПланОбменаСклады.ПланОбменаСсылка
		|ИЗ
		|	втПеремещениеТоваров КАК втПеремещениеТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втПланОбменаСклады КАК втПланОбменаСклады
		|		ПО втПеремещениеТоваров.СкладПолучатель = втПланОбменаСклады.Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втОбъеденить.ПеремещениеТоваровСсылка КАК ПеремещениеТоваровСсылка,
		|	МАКСИМУМ(втОбъеденить.УзелОтправитель) КАК УзелОтправитель,
		|	МАКСИМУМ(втОбъеденить.УзелПолучатель) КАК УзелПолучатель
		|ПОМЕСТИТЬ втУзелОтправительПолучательПеремещения
		|ИЗ
		|	втОбъеденить КАК втОбъеденить
		|
		|СГРУППИРОВАТЬ ПО
		|	втОбъеденить.ПеремещениеТоваровСсылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втПеремещениеТоваров.ПеремещениеТоваровСсылка КАК ДокументОснования,
		|	втПеремещениеТоваров.Проведен КАК ДокументОснованияПроведен,
		|	втПеремещениеТоваров.Номер КАК НомерДокументаВWMS,
		|	втПеремещениеТоваров.Дата КАК ДатаДокументаВWMS,
		|	втПеремещениеТоваров.Комментарий КАК Комментарий,
		|	ВЫБОР
		|		КОГДА втУзелОтправительПолучательПеремещения.УзелОтправитель = втУзелОтправительПолучательПеремещения.УзелПолучатель
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ПеремещениеВнутриУзлаОбмена
		|ИЗ
		|	втПеремещениеТоваров КАК втПеремещениеТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втУзелОтправительПолучательПеремещения КАК втУзелОтправительПолучательПеремещения
		|		ПО втПеремещениеТоваров.ПеремещениеТоваровСсылка = втУзелОтправительПолучательПеремещения.ПеремещениеТоваровСсылка");
	
	Запрос.УстановитьПараметр("ПеремещениеТоваровСсылка", ПеремещениеТоваровСсылка);
	Выборка = Запрос.Выполнить().Выбрать();	
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.ПеремещениеВнутриУзлаОбмена Тогда 
			
			СозданиеПриемки = ax_СинхронизацияПриемкиОтгрузкиТоваров
				.НовыйСозданиеОрдераСтруктура();
			
			ЗаполнитьЗначенияСвойств(СозданиеПриемки, Выборка);
			
			ax_СинхронизацияПриемкиОтгрузкиТоваров.УстановитьФактПриемки(СозданиеПриемки, "Принята");
			
			СозданиеОтгрузки = ax_СинхронизацияПриемкиОтгрузкиТоваров
				.НовыйСозданиеОрдераСтруктура();
				
			ЗаполнитьЗначенияСвойств(СозданиеОтгрузки, Выборка);
			
			СозданиеОтгрузки.СтатусДокументаВWMS = "Отгружен";
			
			ax_СинхронизацияПриемкиОтгрузкиТоваров.УстановитьФактОтгрузки(СозданиеОтгрузки);
			
			Результат = СозданиеПриемки.Результат И СозданиеОтгрузки.Результат;
			
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

