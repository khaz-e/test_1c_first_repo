Функция ВыгрузитьКомплектацияНоменклатуры_ОжидаемаяПриемка(КомплектацияОбъект, Узел)
	
	// Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;
	
	// Организация
	ВыгрузитьОрганизацию(КомплектацияОбъект.Организация,Узел);
	
	// Склад
	ВыгрузитьСклад(КомплектацияОбъект.Склад,Узел);
	
	// Контрагент
	КонтрагентСсылка = Справочники.Контрагенты.НайтиПоНаименованию("Оприходование товаров");
	ВыгрузитьПоставщика(КонтрагентСсылка,Узел);
	
	// Ожидаемая приемка
	ОжидаемаяПриемкаТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axArrivalPlan");
	СтрокаОжПриемкиТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("ID",Строка(КомплектацияОбъект.Ссылка.УникальныйИдентификатор()));
	СтруктураДокумента.Вставить("Date",КомплектацияОбъект.Дата);
	СтруктураДокумента.Вставить("Number","КН" + Прав(КомплектацияОбъект.Номер, СтрДлина(КомплектацияОбъект.Номер)-2));
	СтруктураДокумента.Вставить("OrderSource","ПриемкаИзПроизводства");
	СтруктураДокумента.Вставить("ExpectedDate",КомплектацияОбъект.Дата);
	СтруктураДокумента.Вставить("CounterpartyID",Строка(КонтрагентСсылка.УникальныйИдентификатор()));
	СтруктураДокумента.Вставить("OrganizationID",Строка(КомплектацияОбъект.Организация.УникальныйИдентификатор()));
	СтруктураДокумента.Вставить("Description",КомплектацияОбъект.Комментарий);
	СтруктураДокумента.Вставить("Ссылка",КомплектацияОбъект);
	СтруктураДокумента.Вставить("ContractDate",Дата("00010101"));
	СтруктураДокумента.Вставить("ContractNumber","");
	СтруктураДокумента.Вставить("IsMarked",КомплектацияОбъект.ПометкаУдаления);	
	
	ОбъектXDTO_Приемка          = Фабрика.Создать(ОжидаемаяПриемкаТип);
	ЗаполнитьЗначенияСвойств(ОбъектXDTO_Приемка, СтруктураДокумента);
	
	// Поклажедатель / склад
	Если Узел.ВыгружатьПоклажедателя Тогда    
		ОбъектXDTO_Приемка.Driver = СокрЛП(КомплектацияОбъект.Склад);
	КонецЕсли;	
		
	// Номенклатура
	ВыгрузитьНоменклатуру(КомплектацияОбъект.Номенклатура,Узел);
	
	// Единица
	ВыгрузитьЕдиницу(КомплектацияОбъект.ЕдиницаИзмерения, Узел);
	
	// Партия
	ВыгрузитьПартию(КомплектацияОбъект.Склад, КомплектацияОбъект.Номенклатура, Узел);
	
	// Строки документа "Ожидаемая приемка"
	СтруктураТовары = Новый Структура();
	СтруктураТовары.Вставить("NomenclatureID",Строка(КомплектацияОбъект.Номенклатура.УникальныйИдентификатор()));
	СтруктураТовары.Вставить("StorangeUnitID",Строка(КомплектацияОбъект.ЕдиницаИзмерения.УникальныйИдентификатор()));
	СтруктураТовары.Вставить("TaxRate","БезНДС");
	СтруктураТовары.Вставить("Amount",0);
	
	// Количество план = 0, если документ помечен на удаление
	КоличествоПлан = ?(КомплектацияОбъект.ПометкаУдаления, 0, КомплектацияОбъект.Количество);
	СтруктураТовары.Вставить("Quantity",КоличествоПлан);
	СтруктураТовары.Вставить("QuantityUnit",КоличествоПлан);
	
	//СтруктураТовары.Вставить("LineNum",СтрокаКомплектации.КодСтроки);
	СтруктураТовары.Вставить("QualityID", ПолучитьIDГрадацииКачества(Перечисления.ГрадацииКачества.Новый));
	
	Если Узел.ВыгружатьПартии Тогда
		СтруктураТовары.Вставить("ConsignmentID",Строка(КомплектацияОбъект.Склад.Код) + "_" + Строка(КомплектацияОбъект.Номенклатура.Код));
	Иначе
		СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
	КонецЕсли;
	
	СтруктураТовары.Вставить("Ссылка",КомплектацияОбъект);
	
	ТЧXDTO = Фабрика.Создать(СтрокаОжПриемкиТип);
	ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
	
	ОбъектXDTO_Приемка.GoodsLine.Добавить(ТЧXDTO);
	
	
	РезультатОперации = Прокси.SetArrivalPlan(ОбъектXDTO_Приемка, Узел.Идентификатор);
	
	Возврат РезультатОперации;
	
КонецФункции	

