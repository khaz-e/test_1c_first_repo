#Область ПрограммныйИнтерфейс

// Выполняет запрос к WMS для получения остатков номенклатуры в узле обмена.
//
// Параметры:
//   МассивУИДов - Массив из УникальныйИдентификатор - массив идентификаторов номенклатуры
//   ОстатокНаДату - Дата - дата, на которую запрашиваются остатки
//   УзелОбменаWMS - ПланОбменаСсылка - узел обмена, содержащий параметры подключения к WMS
//   Операция - Строка - вид операции обмена
//
// Возвращаемое значение:
//   Структура:
//     * ЗапросВыполнен - Булево - истина, если запрос выполнен успешно
//     * ОстаткиНоменклатуры - Произвольный - результат запроса остатков
//     * ТекстСообщения - Строка - описание ошибки при неудачном выполнении
Функция ОстаткиНоменклатурыВУзлеОбменаWMS(МассивУИДов, ОстатокНаДату, УзелОбменаWMS, Операция) Экспорт
	
	Пакет = Новый Структура;
	Пакет.Вставить("МассивУИДов", МассивУИДов);
	Пакет.Вставить("ОстатокНаДату", ОстатокНаДату);
	Пакет.Вставить("Операция", Операция);

	РезультатЗапросаGET = Новый Структура("ЗапросВыполнен, ОстаткиНоменклатуры, ТекстСообщения", Ложь, Неопределено, "");
	
	ПараметрыHTTPСоединение = ПараметрыHTTPСоединениеПоУзлуОбмена(УзелОбменаWMS);
	
	HTTPЗапрос = Новый HTTPЗапрос(СтроковыеФункцииКлиентСервер
		.ПодставитьПараметрыВСтроку("%1%2", 
		ПараметрыHTTPСоединение.КорневойURL, ПараметрыHTTPСоединение.ОтносительныйURL));
		
	HTTPЗапрос.УстановитьТелоИзСтроки(ОбщегоНазначения.ЗначениеВСтрокуXML(Пакет));
	
	СтруктураHTTPСоединение = НовыйHTTPСоединение(ПараметрыHTTPСоединение);
	
	Если НЕ СтруктураHTTPСоединение.Ошибка Тогда
		ВыполнитьHTTPЗапросGET(СтруктураHTTPСоединение.Соединение, HTTPЗапрос, РезультатЗапросаGET);
	Иначе
		РезультатЗапросаGET.ТекстСообщения = СтруктураHTTPСоединение.ТекстОшибки;
	КонецЕсли;
		
	Возврат РезультатЗапросаGET;
		
КонецФункции

// Присваивает уникальные возрастающие коды строкам табличной части, у которых код равен 0
//
// Параметры:
//   Объект - ДокументОбъект - содержащий табличную часть и реквизит с максимальным кодом
//   ИмяТабличнойЧасти - Строка - имя табличной части объекта
//   РеквизитМаксимальныйКодСтроки - Строка - имя реквизита объекта, хранящего максимальный код строки
//   ИмяРеквизитаТЧ - Строка - имя реквизита табличной части для хранения кода строки
Процедура УстановитьКлючВСтрокахТабличнойЧасти(Объект,
											ИмяТабличнойЧасти,
											РеквизитМаксимальныйКодСтроки = "ax_МаксимальныйКодСтроки",
											ИмяРеквизитаТЧ = "ax_КодСтроки") Экспорт

	СтрокиБезКлюча = Объект[ИмяТабличнойЧасти].НайтиСтроки(Новый Структура(ИмяРеквизитаТЧ, 0));
	Если СтрокиБезКлюча.Количество() > 0 Тогда
		
		ТекущийКод = Объект[РеквизитМаксимальныйКодСтроки];
		
		Для Каждого СтрокаТовары Из СтрокиБезКлюча Цикл
			
			ТекущийКод = ТекущийКод + 1;
			СтрокаТовары[ИмяРеквизитаТЧ] = ТекущийКод;
			
		КонецЦикла;
		
		Объект[РеквизитМаксимальныйКодСтроки] = ТекущийКод;
		
	КонецЕсли;

КонецПроцедуры

// Записывает событие обмена данными с системой WMS в журнал регистрации.
//
// Параметры:
//   Комментарий - Строка - текст сообщения для записи в журнал
//   Уровень - Строка - уровень важности записи, используется как ключ в массиве УровеньЖурналаРегистрации. По умолчанию: "Ошибка"
//   ОбъектМетаданных - Произвольный - объект метаданных, связанный с событием. По умолчанию: Неопределено
//   Данные - Произвольный - дополнительные данные для записи в журнал. По умолчанию: Неопределено
Процедура ЗаписатьВЖурналРегистрации(
						Комментарий,
						Уровень = "Ошибка", 
						ОбъектМетаданных = Неопределено, 
						Данные = Неопределено) Экспорт 
	
	ЗаписьЖурналаРегистрации(
		"axExchange", 
		УровеньЖурналаРегистрации[Уровень], 
		ОбъектМетаданных, 
		Данные, 
		Комментарий);	
	
КонецПроцедуры

