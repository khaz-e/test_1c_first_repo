Функция ВыгрузитьОрганизацию(Организация, Узел) Экспорт
	
	// Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;
	
	// Организация
	ОрганизацияТип    = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axOrganization");
	КонтИнформацияТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axContactInformation");
	
	СтруктураОрганизация = Новый Структура();
	СтруктураОрганизация.Вставить("ID",Строка(Организация.УникальныйИдентификатор()));
	СтруктураОрганизация.Вставить("Code",Строка(Организация.Код));
	СтруктураОрганизация.Вставить("Name",Строка(Организация.Наименование));
	СтруктураОрганизация.Вставить("FullName",Строка(Организация.НаименованиеПолное));
	СтруктураОрганизация.Вставить("INN",Строка(Организация.ИНН));
	СтруктураОрганизация.Вставить("KPP",Строка(Организация.КПП));
	СтруктураОрганизация.Вставить("OKPO",Строка(Организация.КодПоОКПО));
	СтруктураОрганизация.Вставить("OGRN","");
	СтруктураОрганизация.Вставить("LegalEntity",Ложь);
	СтруктураОрганизация.Вставить("Ссылка",Организация.Ссылка);
	
	ОбъектXDTO        = Фабрика.Создать(ОрганизацияТип);
	ЗаполнитьЗначенияСвойств(ОбъектXDTO, СтруктураОрганизация);
	РезультатОперации = Прокси.SetOrganization(ОбъектXDTO, Узел.Идентификатор);
	
	Возврат РезультатОперации;
	
КонецФункции	

Процедура axОбменПоWebСервису() Экспорт
	
	ВыборкаУзлов = ПланыОбмена.ОбменУправлениеТорговлейWMS4.Выбрать();
	
	Пока ВыборкаУзлов.Следующий() Цикл
		Если ВыборкаУзлов.Ссылка = ПланыОбмена.ОбменУправлениеТорговлейWMS4.ЭтотУзел() Тогда
			Продолжить;
		КонецЕсли;	
		Если НЕ ВыборкаУзлов.Используется Тогда
			Продолжить;
		КонецЕсли;
		
		Результат = Ложь;
		
		НомерОтправленного = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыборкаУзлов.Ссылка, "НомерОтправленного") + 1;
		ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(ВыборкаУзлов.Ссылка, НомерОтправленного);
		Пока ВыборкаИзменений.Следующий() Цикл
			
			ОбъектВыгрузки = ВыборкаИзменений.Получить();
			
			Если ТипЗнч(ОбъектВыгрузки) = Тип("СправочникОбъект.Номенклатура") Тогда
				Результат = ВыгрузитьНоменклатуру(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
				Если Результат Тогда
					ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
				КонецЕсли;	
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("СправочникОбъект.УпаковкиЕдиницыИзмерения") Тогда
				
				Результат = ВыгрузитьЕдиницу(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
				
				// ОбъектВыгрузки.Владелец в УТ 11 владельцем не всегда является Номенклатура (НаборыУпаковок)
				//Если НЕ Результат Тогда
				//	Результат = ВыгрузитьНоменклатуру(ОбъектВыгрузки.Владелец,ВыборкаУзлов.Ссылка);
				//	Результат = ВыгрузитьЕдиницу(ОбъектВыгрузки,ВыборкаУзлов.Ссылка);
				//КонецЕсли;	
				
				Если Результат Тогда
					ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
				КонецЕсли;	
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.СкладПолучатель) <> Неопределено
					И ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.СкладОтправитель) <> Неопределено Тогда 
					
					Результат = Ложь;
					ВыполнитьПеремещениеВнутриОдногоУзла(ОбъектВыгрузки.Ссылка, Результат);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;
									
				ИначеЕсли ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.СкладПолучатель) <> Неопределено Тогда
					
					// Ожидаемая приемка
					Результат = ВыгрузитьПеремещение_ОжидаемаяПриемка(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;
					
				ИначеЕсли ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.СкладОтправитель) <> Неопределено Тогда
					
					// Заказ на отгрузку
					Результат = ВыгрузитьПеремещение_ЗаказНаОтгрузку(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;	
					
				Иначе
					// Удаляем регистрацию. Нужно статус менять в перемещении, а не менять в документе реквизиты
					ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
				КонецЕсли;	
									
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.КорректировкаРеализации") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Ожидаемая приемка
					
					Результат = Выгрузить_КорректировкаРеализации_ОжидаемаяПриемка(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						// Заказ на отгрузку
						
						Результат = Выгрузить_КорректировкаРеализации_ЗаказНаОтгрузку(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					КонецЕсли;	
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
					
				Иначе
					// Удаляем регистрацию. Нужно статус менять в перемещении, а не менять в документе реквизиты
					ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
				КонецЕсли;	
					
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Заказ на отгрузку
					
					Результат = ВыгрузитьРеализацию_ЗаказНаОтгрузку(ОбъектВыгрузки,ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
				Иначе 
					// при регистрации объекта происходить проверка поля Склад и у ссылки этого объекта и самомго объекта
					// это приведет к тому что объект, если он на текущий момент изменил значение поля склад, не регистрируется,
					// но у ссылки поле склад не изменился еще, то есть объект проходит регистрацию (проверка происходит перед записи)
					// но так как при выгрузке происходит проверка склада, то этот объект зависает,
					// он не может быть выгружен так как склад не подходит, остается удалят объект вручную
					// в ут 10 вроде также было, но не понятно как там попдобное решалось (код не сильно отличается)
					ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
				КонецЕсли;	 
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ПередачаТоваровХранителю") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Заказ на отгрузку
					
					Результат = ВыгрузитьПередачаТоваровКомиссионеру_ЗаказНаОтгрузку(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;	
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ЗаказПоставщику") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Заказ поставщику
					
					Результат = ВыгрузитьЗаказПоставщику_ОжидаемаяПриемка(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;	
				Иначе
					ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
				КонецЕсли;	
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ПоступлениеТоваровОтХранителя") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					
					Результат = ВыгрузитьПоступлениеТоваровОтКомиссионера_ОжидаемаяПриемка(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;	
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ВозвратТоваровПоставщику") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Заказ поставщику
					
					Результат = Выгрузить_ВозвратТоваровПоставщику_ЗаказНаОтгрузку(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ВозвратТоваровОтКлиента") Тогда // +
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Возврат товаров от покупателя					
					Результат = ВыгрузитьВозвратТоваровОтПокупателя_ОжидаемаяПриемка(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;	
			
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ОприходованиеИзлишковТоваров") Тогда	
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад)<>Неопределено Тогда
					// Оприходование товаров
					
					Результат = ВыгрузитьОприходованиеТоваров_ОжидаемаяПриемка(ОбъектВыгрузки,ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;	
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.СписаниеНедостачТоваров") Тогда
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад) <> Неопределено Тогда
					// Списание товаров
					
					Результат = ВыгрузитьСписаниеТоваров_ЗаказНаОтгрузку(ОбъектВыгрузки,ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;	
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.ВнутреннееПотребление") Тогда
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад) <> Неопределено Тогда
					// Внутреннее потребление
					
					Результат = ВыгрузитьВнутреннееПотребление_ЗаказНаОтгрузку(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;	
				
			ИначеЕсли ТипЗнч(ОбъектВыгрузки) = Тип("ДокументОбъект.СборкаТоваров") Тогда
				
				Если ВыборкаУзлов.Склады.Найти(ОбъектВыгрузки.Склад) <> Неопределено Тогда
					
					Результат = ВыгрузитьКомплектацияНоменклатуры_ВнутреннийЗаказ(ОбъектВыгрузки, ВыборкаУзлов.Ссылка);
					
					//// Заказ на отгрузку
					//Результат = ВыгрузитьКомплектацияНоменклатуры_ЗаказНаОтгрузку(ОбъектВыгрузки,ВыборкаУзлов.Ссылка);
					//
					//Если Результат Тогда
					//	// Ожидаемая приемка	
					//	Результат = ВыгрузитьКомплектацияНоменклатуры_ОжидаемаяПриемка(ОбъектВыгрузки,ВыборкаУзлов.Ссылка);
					//КонецЕсли;	

					Если Результат Тогда
						ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка,ОбъектВыгрузки);
					КонецЕсли;	
				КонецЕсли;

			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
