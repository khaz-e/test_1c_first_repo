Функция ПолучитьIDГрадацииКачества(Качество)
	
	// в УТ 11 нет справочника с качеством, но есть перечисление у которого нет метода 
	// УникальныйИдентификатор(). Поэтому уникальный идентификатор получаю запросом
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ГрадацииКачества.Ссылка) КАК УникальныйИдентификатор
		|ИЗ
		|	Перечисление.ГрадацииКачества КАК ГрадацииКачества
		|ГДЕ
		|	ГрадацииКачества.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Качество);	
	ГрадацииКачества = Запрос.Выполнить().Выбрать();
	ГрадацииКачества.Следующий();
	
	Возврат Строка(ГрадацииКачества.УникальныйИдентификатор);
	
КонецФункции


