		ДополнительныеРеквизитыТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axComplementaryElements");
			
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID",Строка(КомплектацияСсылка.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Number","КН" + Прав(КомплектацияСсылка.Номер, СтрДлина(КомплектацияСсылка.Номер)-2));	
		СтруктураДокумента.Вставить("NumberCIS","КН" + Прав(КомплектацияСсылка.Номер, СтрДлина(КомплектацияСсылка.Номер)-2));
		СтруктураДокумента.Вставить("Date",КомплектацияСсылка.Дата);
		СтруктураДокумента.Вставить("DateCIS",КомплектацияСсылка.Дата);                      
		Если КомплектацияСсылка.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СборкаТоваров Тогда 
			СтруктураДокумента.Вставить("OrderType","Сборка");	
		Иначе                                                           
			СтруктураДокумента.Вставить("OrderType","Разборка");
		КонецЕсли;
		СтруктураДокумента.Вставить("OrganizationID",Строка(КомплектацияСсылка.Организация.УникальныйИдентификатор()));
