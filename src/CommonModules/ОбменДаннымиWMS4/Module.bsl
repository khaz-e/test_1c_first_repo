Функция ВыгрузитьПартию(Партия, Номенклатура, Узел)
	
	// Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;

	// Партия номенклатуры
	ПартияТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axConsignment");
	
	СтруктураПартия = Новый Структура();
	СтруктураПартия.Вставить("NomenclatureID", Строка(Номенклатура.УникальныйИдентификатор()));
	СтруктураПартия.Вставить("ID", Строка(Партия.Код) + "_" + Строка(Номенклатура.Код));
	СтруктураПартия.Вставить("Name", Строка(Партия.Наименование));
	СтруктураПартия.Вставить("Code", Строка(Партия.Код));
	СтруктураПартия.Вставить("ConsignmentDate", Дата("00010101"));
	
	КонтрагентСклада = ПолучитьКонтрагентаСклада(Партия.Ссылка);
	Если ЗначениеЗаполнено(КонтрагентСклада) Тогда
		ВыгрузитьПокупателя(КонтрагентСклада, Узел);
	КонецЕсли;	
	
	//СтруктураПартия.Вставить("СertificateNumber", Строка(КонтрагентСклада.УникальныйИдентификатор()));
	СтруктураПартия.Вставить("ProductionDate", Дата("00010101"));
	СтруктураПартия.Вставить("ExpirationDate", Дата("00010101"));
	//СтруктураПартия.Вставить("CustomsEntryNumber", ПолучитьНаименованиеНоменклатурыПокупателя(Партия, Номенклатура));
	СтруктураПартия.Вставить("Ссылка", Партия.Ссылка);
	
	ОбъектXDTO = Фабрика.Создать(ПартияТип);
	ЗаполнитьЗначенияСвойств(ОбъектXDTO, СтруктураПартия);     
	
	РезультатОперации = Прокси.SetConsignment(ОбъектXDTO, Узел.Идентификатор);
	
	Возврат РезультатОперации;
	
КонецФункции	

Функция ПолучитьНаименованиеНоменклатурыПокупателя(Склад, Номенклатура)
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗначенияСвойствОбъектов.Объект КАК Контрагент
	|ПОМЕСТИТЬ тКонтрагенты
	|ИЗ
	|	РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Свойство.Наименование = ""Склад""
	|	И ЗначенияСвойствОбъектов.Значение = &Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НоменклатураКонтрагентов.НаименованиеНоменклатурыКонтрагента
	|ИЗ
	|	РегистрСведений.НоменклатураКонтрагентов КАК НоменклатураКонтрагентов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ тКонтрагенты КАК тКонтрагенты
	|		ПО НоменклатураКонтрагентов.Контрагент = тКонтрагенты.Контрагент
	|ГДЕ
	|	НоменклатураКонтрагентов.Номенклатура = &Номенклатура
	|	И НоменклатураКонтрагентов.Контрагент = тКонтрагенты.Контрагент";
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат СокрЛП(Выборка.НаименованиеНоменклатурыКонтрагента);
	КонецЕсли;
	
	Возврат СокрЛП(Номенклатура.Наименование);
	
КонецФункции	

Функция ВыгрузитьПеремещение_ОжидаемаяПриемка(ПеремещениеСсылка, Узел)
	
	Склады = Новый Массив;
	Склады.Добавить(ПеремещениеСсылка.СкладОтправитель);
	Склады.Добавить(ПеремещениеСсылка.СкладПолучатель);
	
	ЗначенияРеквизитовСкладов = ЗначенияРеквизитовСкладов(Склады, "Ссылка, Наименование");
			
	Попытка
	
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль       = Узел.Пароль;
		
		Фабрика = Прокси.ФабрикаXDTO;
		
		// Организация
		ВыгрузитьОрганизацию(ПеремещениеСсылка.Организация, Узел); //
		
		// Поставщик
		//ВыгрузитьСклад(ПеремещениеСсылка.СкладОтправитель, Узел); //
		ВыгрузитьСклад(
			ЗначенияРеквизитовСкладов[ПеремещениеСсылка.СкладОтправитель], Узел);
		
		
		// Ожидаемая приемка
		ОжидаемаяПриемкаТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axArrivalPlan");
		СтрокаОжПриемкиТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
		
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID",Строка(ПеремещениеСсылка.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Date",ПеремещениеСсылка.Дата);
		СтруктураДокумента.Вставить("Number","ПМ" + Прав(ПеремещениеСсылка.Номер, СтрДлина(ПеремещениеСсылка.Номер)-2));
		СтруктураДокумента.Вставить("OrderSource","ПриемкаСоСклада");
		СтруктураДокумента.Вставить("ExpectedDate",ПеремещениеСсылка.Дата);
		СтруктураДокумента.Вставить("CounterpartyID",Строка(ПеремещениеСсылка.СкладОтправитель.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("OrganizationID",Строка(ПеремещениеСсылка.Организация.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Description",ПеремещениеСсылка.ax_КомментарийСклад);
		СтруктураДокумента.Вставить("Ссылка",ПеремещениеСсылка);
		СтруктураДокумента.Вставить("ContractDate",Дата("00010101"));
		СтруктураДокумента.Вставить("ContractNumber","");
		СтруктураДокумента.Вставить("IsMarked", ПеремещениеСсылка.ПометкаУдаления);	
		
		ОбъектXDTO_Приемка          = Фабрика.Создать(ОжидаемаяПриемкаТип);
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_Приемка, СтруктураДокумента);
		
		// Поклажедатель / склад
		Если Узел.ВыгружатьПоклажедателя Тогда    
			
			ОбъектXDTO_Приемка.Driver = СокрЛП(ПеремещениеСсылка.СкладПолучатель);
			
		КонецЕсли;	

		
		Для Каждого СтрокаПеремещение Из ПеремещениеСсылка.Товары Цикл
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаПеремещение.Номенклатура,Узел); //
			
			// Единица
			Единица = ?(
				СтрокаПеремещение.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
				СтрокаПеремещение.Упаковка,
				СтрокаПеремещение.Номенклатура.ЕдиницаИзмерения
			);
			
			ВыгрузитьЕдиницу(Единица, Узел);
			
			УпаковкаId = ?(
				СтрокаПеремещение.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
				Строка(СтрокаПеремещение.Упаковка.УникальныйИдентификатор()),
				"00000000-0000-0000-0000-000000000000"
			);
			
			// Качество
			ВыгрузитьКачество(СтрокаПеремещение.Номенклатура.Качество, Узел); //
			
			// Партия
			//ВыгрузитьПартию(ПеремещениеСсылка.СкладПолучатель, СтрокаПеремещение.Номенклатура, Узел); 
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[ПеремещениеСсылка.СкладПолучатель], 
				СтрокаПеремещение.Номенклатура, Узел);
			
			// Строки документа "Ожидаемая приемка"
			СтруктураТовары = Новый Структура();
			СтруктураТовары.Вставить("NomenclatureID", Строка(СтрокаПеремещение.Номенклатура.УникальныйИдентификатор()));
			//СтруктураТовары.Вставить("StorangeUnitID", Строка(Единица.УникальныйИдентификатор()));
			СтруктураТовары.Вставить("StorangeUnitID", УпаковкаId);
			СтруктураТовары.Вставить("TaxRate","БезНДС");
			//СтруктураТовары.Вставить("Amount",СтрокаПеремещение.Цена);
			// Пока не знаю как расчитать цену, поле цена отсутсвует в ТЧ товары
			СтруктураТовары.Вставить("Amount","");
			
			// Количество план = 0, если документ помечен на удаление
			КоличествоПлан = ?(ПеремещениеСсылка.ПометкаУдаления, 0, СтрокаПеремещение.КоличествоУпаковок);
			СтруктураТовары.Вставить("Quantity",КоличествоПлан);
			СтруктураТовары.Вставить("QuantityUnit",КоличествоПлан);
			
			// СтруктураТовары.Вставить("LineNum",СтрокаПеремещение.КодСтроки);
