		//	ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "Поклажедатель";
		//	ОбъектXDTO_ДополнительныеРеквизиты.Value = СокрЛП(КомплектацияСсылка.Склад);
		//	
		//	ОбъектXDTO_ВнутреннийЗаказ.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
		//	
		//КонецЕсли;	
		
		ОбъектXDTO_Спецификация = Фабрика.Создать(КомплектацияВнутреннийЗаказТип);
		ОбъектXDTO_Спецификация.OwnerID = Строка(КомплектацияСсылка.Номенклатура.УникальныйИдентификатор());
		ОбъектXDTO_Спецификация.Name = Строка("Спецификация " + КомплектацияСсылка.Номенклатура.Наименование);
		
		Для Каждого СтрокаКомплектация Из КомплектацияСсылка.Товары Цикл
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаКомплектация.Номенклатура,Узел);
			
			// Единица
			Единица = ?(
				СтрокаКомплектация.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
				СтрокаКомплектация.Упаковка,
				СтрокаКомплектация.Номенклатура.ЕдиницаИзмерения
			);
			ВыгрузитьЕдиницу(Единица, Узел);
			
			// Партия
			//ПартияСоздана = ВыгрузитьПартию(КомплектацияСсылка.Склад, КомплектацияСсылка.Номенклатура, Узел);
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[КомплектацияСсылка.Склад],
