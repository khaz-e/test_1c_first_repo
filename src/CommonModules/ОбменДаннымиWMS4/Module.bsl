Функция ВыгрузитьРеализацию_ЗаказНаОтгрузку(РеализацияСсылка, Узел)
	
	ЗначенияРеквизитовСкладов = ЗначенияРеквизитовСкладов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РеализацияСсылка.Склад),
		"Ссылка, Наименование");
	
	Попытка
	
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль = Узел.Пароль;
		
		Фабрика = Прокси.ФабрикаXDTO;
		
		// Организация
		ВыгрузитьОрганизацию(РеализацияСсылка.Организация, Узел);
		
		// Покупатель
		ВыгрузитьПокупателя(РеализацияСсылка.Контрагент, Узел);
		
		// Заказ на отгрузку
		ЗаказНаОтгрузкуТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axShippingPlan");
		СтрокаЗаказНаОтгрузкуТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
		
		// Доп. реквизиты. Поклажедатель (склад)
		ДополнительныеРеквизитыТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axComplementaryElements");
		
		
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID",Строка(РеализацияСсылка.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Date",РеализацияСсылка.Дата);
		СтруктураДокумента.Вставить("Number","РТ" + Прав(РеализацияСсылка.Номер, СтрДлина(РеализацияСсылка.Номер)-2)); // "РТ" + Прав(РеализацияСсылка.Номер, СтрДлина(РеализацияСсылка.Номер)-2);
		СтруктураДокумента.Вставить("ShipmentDirection",?(ЗначениеЗаполнено(РеализацияСсылка.ax_ТДФДатаЗавоза),"ОтгрузкаКлиенту","Самовывоз"));
		СтруктураДокумента.Вставить("Priority","Обычная");
		СтруктураДокумента.Вставить("ExpectedDate", ?(ЗначениеЗаполнено(РеализацияСсылка.ax_ТДФДатаЗавоза), РеализацияСсылка.ax_ТДФДатаЗавоза,РеализацияСсылка.Дата));
		СтруктураДокумента.Вставить("CounterpartyID",Строка(РеализацияСсылка.Контрагент.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("OrganizationID",Строка(РеализацияСсылка.Организация.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Description", РеализацияСсылка.ax_КомментарийСклад);
		СтруктураДокумента.Вставить("Ссылка", РеализацияСсылка);
		СтруктураДокумента.Вставить("DeliveryAddress", РеализацияСсылка.АдресДоставки);
		СтруктураДокумента.Вставить("DeliveryComment", РеализацияСсылка.АдресДоставки);
		СтруктураДокумента.Вставить("ContractDate", Дата("00010101"));
		СтруктураДокумента.Вставить("ContractNumber","");
		СтруктураДокумента.Вставить("IsMarked", РеализацияСсылка.ax_ОтменитьЗаказ ИЛИ РеализацияСсылка.ПометкаУдаления);
		
		ОбъектXDTO_ЗаказНаОтгрузку = Фабрика.Создать(ЗаказНаОтгрузкуТип);
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_ЗаказНаОтгрузку, СтруктураДокумента);    
		
		// Поклажедатель / склад
		Если Узел.ВыгружатьПоклажедателя Тогда
			
			ОбъектXDTO_ДополнительныеРеквизиты = Фабрика.Создать(ДополнительныеРеквизитыТип);
			ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "Поклажедатель";
			ОбъектXDTO_ДополнительныеРеквизиты.Value = СокрЛП(РеализацияСсылка.Склад);
			
			ОбъектXDTO_ЗаказНаОтгрузку.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
			
		КонецЕсли;	
		
		Для Каждого СтрокаРеализация Из РеализацияСсылка.Товары Цикл
			
			Если СтрокаРеализация.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда 
				Продолжить;
			КонецЕсли;
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаРеализация.Номенклатура, Узел);
			
			// Единица
			Единица = ?(СтрокаРеализация.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
						СтрокаРеализация.Упаковка, СтрокаРеализация.Номенклатура.ЕдиницаИзмерения);
			ВыгрузитьЕдиницу(Единица, Узел);
			
			// Качество
			ВыгрузитьКачество(СтрокаРеализация.Номенклатура.Качество, Узел);
			
			// Партия
			//ПартияСоздана = ВыгрузитьПартию(РеализацияСсылка.Склад, СтрокаРеализация.Номенклатура, Узел);
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[РеализацияСсылка.Склад], 
				СтрокаРеализация.Номенклатура, Узел);
			
			// Строки документа "Заказ на отгрузку"
			СтруктураТовары = Новый Структура();
			СтруктураТовары.Вставить("NomenclatureID",Строка(СтрокаРеализация.Номенклатура.УникальныйИдентификатор()));
			СтруктураТовары.Вставить("StorangeUnitID",Строка(Единица.УникальныйИдентификатор()));
			
			// StorangeUnitID -- как я понял, это упаковка потому указал именно упаковку
			// я попробывал базовую единицу измерения, но он все равно отрабатывает без ошибки
			// пока оставлю как упаковку
			//СтруктураТовары.Вставить("StorangeUnitID",Строка(Единица.УникальныйИдентификатор()));
			
			СтруктураТовары.Вставить("TaxRate","БезНДС");
			СтруктураТовары.Вставить("Amount",СтрокаРеализация.Цена);
			
			// Количество план = 0, если документ помечен на удаление
			КоличествоПлан = ?(РеализацияСсылка.ax_ОтменитьЗаказ ИЛИ РеализацияСсылка.ПометкаУдаления, 0, СтрокаРеализация.Количество);
			СтруктураТовары.Вставить("Quantity", КоличествоПлан);
			СтруктураТовары.Вставить("QuantityUnit", КоличествоПлан);
			СтруктураТовары.Вставить("LineNum", СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(СтрокаРеализация.ax_КодСтроки), 10, "0", "Слева"));
			
			// В УТ 10 качество это справочник
			//СтруктураТовары.Вставить("QualityID",Строка(СтрокаРеализация.Номенклатура.Качество.УникальныйИдентификатор()));
			
			// В УТ 11 качество задается перечислением ГрадацииКачества
			// Уникальный идентификатор у перечисления можно получить через запрос
			// Создана функция ПолучитьIDГрадацииКачества()
			СтруктураТовары.Вставить("QualityID",ПолучитьIDГрадацииКачества(СтрокаРеализация.Номенклатура.Качество));
			
			// в коде ВМС нет создания соответствия идентификатора элементу справочника качества
			// похоже он создавался вручную
			// решили заменить в регистре усИдентификаторыОбмена - "Идентификаторы обмена (web-сервис)"
			// Кондиция		d05404a0-6bce-449b-a798-41ebe5e5b977 (этот идентификатор использовался в УТ 10)
			// на 
			// Кондиция		b21b212c-ce0e-477b-be8e-0fc91014bfea (этот идентификатор возвращает ПолучитьIDГрадацииКачества в УТ 11)
			
			Если Узел.ВыгружатьПартии Тогда
				
				//СтруктураТовары.Вставить("ConsignmentID",Строка(РеализацияСсылка.Склад.Код) + "_" + Строка(СтрокаРеализация.Номенклатура.Код));
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[РеализацияСсылка.Склад].Код;
				
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаРеализация.Номенклатура.Код)));	
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка", РеализацияСсылка);
			
			ТЧXDTO = Фабрика.Создать(СтрокаЗаказНаОтгрузкуТип);
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Добавить(ТЧXDTO);
		КонецЦикла;
		
		РезультатОперации = Прокси.SetShippingPlan(ОбъектXDTO_ЗаказНаОтгрузку, Узел.Идентификатор);
		
		Возврат РезультатОперации;
		
	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине:
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, РеализацияСсылка.Метаданные(), РеализацияСсылка.Ссылка);
		
		Возврат Ложь;
		
	КонецПопытки;
	
КонецФункции	

