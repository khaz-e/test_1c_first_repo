Функция ВыгрузитьЗаказПоставщику_ОжидаемаяПриемка(ЗаказПоставщикуСсылка, Узел)
	
	ЗначенияРеквизитовСкладов = ЗначенияРеквизитовСкладов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ЗаказПоставщикуСсылка.Склад),
		"Ссылка, Наименование");
	
	Попытка
	
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль       = Узел.Пароль;
		
		Фабрика = Прокси.ФабрикаXDTO;
		
		// Организация
		ВыгрузитьОрганизацию(ЗаказПоставщикуСсылка.Организация, Узел);
		
		// Склад
		//ВыгрузитьСклад(ЗаказПоставщикуСсылка.Склад, Узел);
		ВыгрузитьСклад(
			ЗначенияРеквизитовСкладов[ЗаказПоставщикуСсылка.Склад], Узел);
		
		
		// Поставщик
		ВыгрузитьПоставщика(ЗаказПоставщикуСсылка.Контрагент, Узел);
		
		// Ожидаемая приемка
		ОжидаемаяПриемкаТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axArrivalPlan");
		СтрокаОжПриемкиТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
		
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ID",Строка(ЗаказПоставщикуСсылка.Ссылка.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Date",ЗаказПоставщикуСсылка.Дата);
		СтруктураДокумента.Вставить("Number","ЗП" + Прав(ЗаказПоставщикуСсылка.Номер, СтрДлина(ЗаказПоставщикуСсылка.Номер)-2));
		СтруктураДокумента.Вставить("OrderSource","ПриемкаОтПоставщика");
		// 2022.04.20 1c_dev2 [start]
		// ExpectedDate = ДатаПоступления в Ожидаемой приемке WMS 
		// Передадим в нее ДатаПоступления из Заказа поставщику
		//СтруктураДокумента.Вставить("ExpectedDate",ЗаказПоставщикуСсылка.Дата);
		СтруктураДокумента.Вставить("ExpectedDate",?(ЗначениеЗаполнено(ЗаказПоставщикуСсылка.ДатаПоступления),ЗаказПоставщикуСсылка.ДатаПоступления,ЗаказПоставщикуСсылка.Дата));
		// 2022.04.20 1c_dev2 [end]
		СтруктураДокумента.Вставить("CounterpartyID",Строка(ЗаказПоставщикуСсылка.Контрагент.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("OrganizationID",Строка(ЗаказПоставщикуСсылка.Организация.УникальныйИдентификатор()));
		СтруктураДокумента.Вставить("Description",ЗаказПоставщикуСсылка.ax_КомментарийСклад);
		СтруктураДокумента.Вставить("Ссылка",ЗаказПоставщикуСсылка);
		СтруктураДокумента.Вставить("ContractDate",Дата("00010101"));
		
		//24.01.2022 1c_dev2  Передача приоритета из Заказа поставщику в Ожидаемая приемка
		//СтруктураДокумента.Вставить("ContractNumber","");
		СтруктураДокумента.Вставить("ContractNumber",Строка(ЗаказПоставщикуСсылка.Приоритет));
		//1c_dev2
		
		СтруктураДокумента.Вставить("IsMarked",ЗаказПоставщикуСсылка.ПометкаУдаления);	
		
		ОбъектXDTO_Приемка          = Фабрика.Создать(ОжидаемаяПриемкаТип);
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_Приемка, СтруктураДокумента);
		
		// Поклажедатель / склад
		Если Узел.ВыгружатьПоклажедателя Тогда    
			
			ОбъектXDTO_Приемка.Driver = СокрЛП(ЗаказПоставщикуСсылка.Склад);
			
		КонецЕсли;	
		
		
		Для Каждого СтрокаЗаказПоставщику Из ЗаказПоставщикуСсылка.Товары Цикл
			
			// Номенклатура
			ВыгрузитьНоменклатуру(СтрокаЗаказПоставщику.Номенклатура,Узел);
			
			// Единица
			Единица = ?(
				СтрокаЗаказПоставщику.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
				СтрокаЗаказПоставщику.Упаковка,
				СтрокаЗаказПоставщику.Номенклатура.ЕдиницаИзмерения);
			ВыгрузитьЕдиницу(Единица, Узел);
			
			УпаковкаId = ?(
				СтрокаЗаказПоставщику.Упаковка <> Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка(),
				Строка(СтрокаЗаказПоставщику.Упаковка.УникальныйИдентификатор()),
				"00000000-0000-0000-0000-000000000000"
			);
			
			// Партия
			ВыгрузитьПартию(
				ЗначенияРеквизитовСкладов[ЗаказПоставщикуСсылка.Склад],
				СтрокаЗаказПоставщику.Номенклатура, Узел);
			
			// Строки документа "Ожидаемая приемка"
			СтруктураТовары = Новый Структура();
			СтруктураТовары.Вставить("NomenclatureID",Строка(СтрокаЗаказПоставщику.Номенклатура.УникальныйИдентификатор()));
			//СтруктураТовары.Вставить("StorangeUnitID",Строка(Единица.УникальныйИдентификатор()));
			
			
			СтруктураТовары.Вставить("StorangeUnitID", УпаковкаId);
			СтруктураТовары.Вставить("TaxRate","БезНДС");
			СтруктураТовары.Вставить("Amount",СтрокаЗаказПоставщику.Цена);
			
			// Количество план = 0, если документ помечен на удаление
			КоличествоПлан = ?(ЗаказПоставщикуСсылка.ПометкаУдаления, 0, СтрокаЗаказПоставщику.Количество);
			СтруктураТовары.Вставить("Quantity",КоличествоПлан);
			СтруктураТовары.Вставить("QuantityUnit",КоличествоПлан);
			
			//СтруктураТовары.Вставить("LineNum", "0000000000");
			СтруктураТовары.Вставить("LineNum", СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(СтрокаЗаказПоставщику.КодСтроки), 10, "0", "Слева"));
			СтруктураТовары.Вставить("QualityID",ПолучитьIDГрадацииКачества(Перечисления.ГрадацииКачества.Новый));
			
			Если Узел.ВыгружатьПартии Тогда
				
				//СтруктураТовары.Вставить("ConsignmentID",Строка(ЗаказПоставщикуСсылка.Склад.Код) + "_" + Строка(СтрокаЗаказПоставщику.Номенклатура.Код));
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[ЗаказПоставщикуСсылка.Склад].Код;
								
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаЗаказПоставщику.Номенклатура.Код)));
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка", ЗаказПоставщикуСсылка);
			
			ТЧXDTO = Фабрика.Создать(СтрокаОжПриемкиТип);
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_Приемка.GoodsLine.Добавить(ТЧXDTO);
		КонецЦикла;
		
		РезультатОперации = Прокси.SetArrivalPlan(ОбъектXDTO_Приемка, Узел.Идентификатор);
		
		Возврат РезультатОперации;
		
	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине:
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, ЗаказПоставщикуСсылка.Метаданные(), ЗаказПоставщикуСсылка.Ссылка);
		
		Возврат Ложь;
		
	КонецПопытки;
	
