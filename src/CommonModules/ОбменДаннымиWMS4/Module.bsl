Функция ОбъектИзменен(Источник)
	ИсточникДоИзменения = Источник.Ссылка;
	ИсточникПослеИзменения = Источник;
	
	// чтобы не запрашивать постоянно метаданные объекта
	ИсточникМетаданные = ИсточникПослеИзменения.Метаданные();
	
	// обход не включает стандартные реквизиты
	Для Каждого Реквизит Из ИсточникМетаданные.Реквизиты Цикл
		Если ИсточникПослеИзменения[Реквизит.Имя] <> ИсточникДоИзменения[Реквизит.Имя] Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	// обход по стандартным реквизитам
	Для Каждого Реквизит Из ИсточникМетаданные.СтандартныеРеквизиты Цикл
		Если ИсточникПослеИзменения[Реквизит.Имя] <> ИсточникДоИзменения[Реквизит.Имя] Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	// Обход по табличным частям
	КоллекцияМетаДанныхТабличныхЧастей = ИсточникМетаданные.ТабличныеЧасти;
	Для Каждого Элемент Из КоллекцияМетаДанныхТабличныхЧастей Цикл 
		ИсточникТабличнаяЧастьДоИзменения = ИсточникДоИзменения[Элемент.Имя];
		ИсточникТабличнаяЧастьПослеИзменения = ИсточникПослеИзменения[Элемент.Имя];
		
		Если ИсточникТабличнаяЧастьДоИзменения.Количество() <> ИсточникТабличнаяЧастьПослеИзменения.Количество() Тогда 
			Возврат Истина;
		КонецЕсли;
		
		ИндексСтрокиТЧ = Источник[Элемент.Имя].Количество() - 1;
		
		Пока НЕ ИндексСтрокиТЧ < 0 Цикл 
			Для Каждого РеквизитТабличнойЧасти Из Элемент.Реквизиты Цикл 
				Если ИсточникТабличнаяЧастьДоИзменения[ИндексСтрокиТЧ][РеквизитТабличнойЧасти.Имя]
				<> ИсточникТабличнаяЧастьПослеИзменения[ИндексСтрокиТЧ][РеквизитТабличнойЧасти.Имя] Тогда 
					Возврат Истина;	
				КонецЕсли;	
			КонецЦикла;
			
			ИндексСтрокиТЧ = ИндексСтрокиТЧ - 1;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Ложь;
КонецФункции

