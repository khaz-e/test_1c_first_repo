// Возвращает остатки номенклатуры на указанных складах.
//
// Параметры:
//   СписокНоменклатуры - Массив из СправочникСсылка.Номенклатура - список номенклатуры для получения остатков
//   Склады - Массив из СправочникСсылка.Склады - список складов для получения остатков
//          - СправочникСсылка.Склады - склад для получения остатков
//
// Возвращаемое значение:
//   РезультатЗапроса - результат запроса с остатками номенклатуры на складах
Функция ОстаткиНоменклатурыНаСкладах(СписокНоменклатуры, Склады) Экспорт 
	
	Возврат ВыполнитьЗапрос(ТекстЗапросаОстаткиНоменклатурыНаСкладах(), 
							Новый Структура("СписокНоменклатуры, Склады", СписокНоменклатуры, Склады));
	
КонецФункции

Функция ТекстЗапросаОстаткиНоменклатурыНаСкладах()	
	ТекстЗапроса = "ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК НоменклатураСсылка,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Номенклатура.Ссылка)) КАК УИДНоменклатуры,
	|	Номенклатура.Представление КАК ПредставлениеНоменклатуры
	|ПОМЕСТИТЬ втСписокНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В(&СписокНоменклатуры)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстаток
	|ПОМЕСТИТЬ втОстаткиНоменклатурыНаСкладах
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(
	|			,
	|			Номенклатура В
	|					(ВЫБРАТЬ
	|						втСписокНоменклатуры.НоменклатураСсылка КАК НоменклатураСсылка
	|					ИЗ
	|						втСписокНоменклатуры КАК втСписокНоменклатуры)
	|				И Склад В (&Склады)) КАК ТоварыНаСкладахОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втСписокНоменклатуры.УИДНоменклатуры КАК УИДНоменклатуры,
	|	втСписокНоменклатуры.ПредставлениеНоменклатуры КАК ПредставлениеНоменклатурыВУТ,
	|	ЕСТЬNULL(втОстаткиНоменклатурыНаСкладах.ВНаличииОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	втСписокНоменклатуры КАК втСписокНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ втОстаткиНоменклатурыНаСкладах КАК втОстаткиНоменклатурыНаСкладах
	|		ПО втСписокНоменклатуры.НоменклатураСсылка = втОстаткиНоменклатурыНаСкладах.Номенклатура";
	
	Возврат ТекстЗапроса;	
КонецФункции

Функция ВыполнитьЗапрос(ТекстЗапроса, ПараметрыЗапросаСтруктура = Неопределено)
	
	СтруктураРезультатЗапроса = Новый Структура("РезультатЗапроса, Ошибка, ОписаниеОшибки", Неопределено, Ложь, "");
	
	Запрос = Новый Запрос (ТекстЗапроса);
	
	Если ПараметрыЗапросаСтруктура <> Неопределено Тогда 
		Для Каждого КлючЗначение Из ПараметрыЗапросаСтруктура Цикл
			Запрос.УстановитьПараметр(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЦикла;
	КонецЕсли;	
	
	Попытка
		СтруктураРезультатЗапроса.РезультатЗапроса = Запрос.Выполнить();		
	Исключение	
		ОписаниеОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Ошибка при выполнении запроса в базу данных:
			|%1'"), ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		СтруктураРезультатЗапроса.Ошибка = Истина; 
		СтруктураРезультатЗапроса.ОписаниеОшибки = ОписаниеОшибки;
	КонецПопытки;
			
	Возврат СтруктураРезультатЗапроса;	
	
КонецФункции

#КонецОбласти

Функция ЗаказПоставщикуПоДокументуВозврата(ДокументВозврат)
	
	ЗаказПоставщикуСтруктура = Новый Структура("ЗаказПоставщику, ЗаказПоставщикуУИД, Ошибка, ОписаниеОшибки");
	
	Запрос = Новый Запрос("ВЫБРАТЬ
		|	ВозвратТоваровПоставщику.Ссылка КАК ВозвратТоваровПоставщикуСсылка,
		|	ВозвратТоваровПоставщику.Представление КАК ВозвратТоваровПоставщикуПредставление,
		|	ПриобретениеТоваровУслуг.Ссылка КАК ПриобретениеТоваровУслугСсылка,
		|	ПриобретениеТоваровУслуг.Представление КАК ПриобретениеТоваровУслугПредставление,
		|	ПриобретениеТоваровУслуг.ЗаказПоставщику КАК ЗаказПоставщику,
		|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриобретениеТоваровУслуг.ЗаказПоставщику)) КАК ЗаказПоставщикуУИД,
		|	ПриобретениеТоваровУслуг.ЗаказПоставщику.Представление КАК ЗаказПоставщикуПредставление,
		|	ВЫБОР
		|		КОГДА ПриобретениеТоваровУслуг.ЗаказПоставщику = ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЗаказПоставщикуОтсутствует,
		|	ЕСТЬNULL(ПриобретениеТоваровУслуг.ЗаказПоставщику.Проведен, ЛОЖЬ) КАК ЗаказПоставщикуПроведен,
		|	ЕСТЬNULL(ПриобретениеТоваровУслуг.ЗаказПоставщику.ax_УС, ЛОЖЬ) КАК ПередатьНаСклад
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровПоставщику КАК ВозвратТоваровПоставщику
		|		ПО ПриобретениеТоваровУслуг.Ссылка = ВозвратТоваровПоставщику.ДокументПоступления
		|ГДЕ
		|	ВозвратТоваровПоставщику.Ссылка = &ВозвратТоваровПоставщикуСсылка");
	
	Запрос.УстановитьПараметр("ВозвратТоваровПоставщикуСсылка", ДокументВозврат);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Если Выборка.ЗаказПоставщикуОтсутствует Тогда 
			ЗаказПоставщикуСтруктура.Ошибка = Истина;
			ЗаказПоставщикуСтруктура.ОписаниеОшибки = СтрШаблон(
				"У документа поступления ""%1"" нет заказа поставщику", Выборка.ПриобретениеТоваровУслугПредставление);
		ИначеЕсли НЕ Выборка.ЗаказПоставщикуПроведен ИЛИ НЕ Выборка.ПередатьНаСклад Тогда 	
			ЗаказПоставщикуСтруктура.Ошибка = Истина;
			ЗаказПоставщикуСтруктура.ОписаниеОшибки = СтрШаблон(
				"Документ ""%1"" не проведен или его не нужно передавать на склад", Выборка.ЗаказПоставщикуПредставление);	
		Иначе 
			ЗаказПоставщикуСтруктура.ЗаказПоставщику = Выборка.ЗаказПоставщику; 
			ЗаказПоставщикуСтруктура.ЗаказПоставщикуУИД  = Выборка.ЗаказПоставщикуУИД;
			ЗаказПоставщикуСтруктура.Ошибка = Ложь;
		КонецЕсли;
	Иначе 	
		ЗаказПоставщикуСтруктура.Ошибка = Истина;
		ЗаказПоставщикуСтруктура.ОписаниеОшибки = "У документа ""Возврат товаров поставщику"" не заполнен реквизит ДокументПоступления";	
	КонецЕсли;
	
	Возврат ЗаказПоставщикуСтруктура;

КонецФункции

#Область ЗапросДанныхИзвне

// Возвращаемое значение:
// 	 Структура: проинициализированная значениями реквизитов передаваемого узла обмена
//				см. ОбщегоНазначенияКлиентСервер.СтруктураURI 
//   	* Хост
//   	* Порт
//   	* Пользователь
//   	* Пароль
//   	* КорневойURL
//   	* ОтносительныйURL
Функция ПараметрыHTTPСоединениеПоУзлуОбмена(УзелОбмена)	
	
	ЗначенияРеквизитовОбъекта = ОбщегоНазначения
		.ЗначенияРеквизитовОбъекта(УзелОбмена, "URL, Пользователь, Пароль, Представление");
		
	СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(ЗначенияРеквизитовОбъекта.URL);
	
	Возврат Новый Структура("Хост, Порт, Пользователь, Пароль, КорневойURL, ОтносительныйURL",
		СтруктураURI.ИмяСервера,
		СтруктураURI.Порт, 
		ЗначенияРеквизитовОбъекта.Пользователь,
		ЗначенияРеквизитовОбъекта.Пароль, 
		Лев(СтруктураURI.ПутьНасервере, СтрНайти(СтруктураURI.ПутьНасервере, "/")),
		"hs/remains_v1/goods");
		
КонецФункции

// Создает объект типа HTTPСоединение, а в случае неудачи обрабатывает ошибку
//
// Параметры:
// 	Структура - см. ПараметрыHTTPСоединениеПоУзлуОбмена
//
// Возвращаемое значение
//	Структуру
//	* Соединение - HTTPСоединение
//	* Ошибка - булево - Истина, если при попытке создания HTTPСоединения - ошибка 
//  * ТекстОшибки - Строка 
//
Функция НовыйHTTPСоединение(ПараметрыСоединения)
	
	СтруктураСоединение = Новый Структура("Соединение, Ошибка, ТекстОшибки", Неопределено, Ложь, "");	
	
	Попытка
		СтруктураСоединение.Соединение = Новый HTTPСоединение(ПараметрыСоединения.Хост, ПараметрыСоединения.Порт, 
			ПараметрыСоединения.Пользователь, ПараметрыСоединения.Пароль,,20,);
	Исключение
		ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось установить соединение с сервером %1 по причине:
			|%2'"), ПараметрыСоединения.Хост, 
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));		
	
		СтруктураСоединение.Ошибка = Истина;
		СтруктураСоединение.ТекстОшибки = ТекстОшибки;
	КонецПопытки;
	
	Возврат СтруктураСоединение;
	
КонецФункции

// выполняет HTTPЗапрос и помещает результат в параметр РезультатЗапроса
//                                                                   
// Параметры:
// 	HTTPСоединение 
//	HTTPЗапрос
//	РезультатЗапроса - Структура:
// 		* ЗапросВыполнен - Булево
//		* ОстаткиНоменклатуры 
//			- Неопределено, если 
//          - Таблица значений
//				** АртикулНоменклатурыWMS
//				** КодНоменклатурыWMS
//				** КодЯчейкиWMS	
//				** ОстатокWMS	
//				** ПредставлениеНоменклатурыWMS	
//				** УИДНоменклатуры	
//				** ШтрихкодЯчейкиWMS	
//		* ТекстСообщения - строка - сообщение о результате выполнения
//
Процедура ВыполнитьHTTPЗапросGET(HTTPСоединение, HTTPЗапрос, РезультатЗапроса)
	
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	
	ШаблонСообщения = НСтр("ru = 'Запрос ""%1"" не выполнен. Код состояния: %2
		|%3'");
				
	Если Ответ.КодСостояния <> 200 Тогда		
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонСообщения, HTTPЗапрос.АдресРесурса, Ответ.КодСостояния, Ответ.ПолучитьТелоКакСтроку());
			
		РезультатЗапроса.ТекстСообщения = СокрЛП(ТекстСообщения);
	Иначе 
		РезультатЗапроса.ОстаткиНоменклатуры = ОбщегоНазначения.ЗначениеИзСтрокиXML(Ответ.ПолучитьТелоКакСтроку());
		РезультатЗапроса.ЗапросВыполнен = Истина;
	КонецЕсли;
	
	Если Ответ.КодСостояния = 401 Или Ответ.КодСостояния = 403 Тогда
		ИнформацияОбОшибке = НСтр("ru = 'Неавторизованный запрос (Unauthorized) 
			|или Доступ к запрашиваемому ресурсу на сервере запрещён'");				
		
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1
			|%2", РезультатЗапроса.ТекстСообщения, ИнформацияОбОшибке);
		РезультатЗапроса.ТекстСообщения = СокрЛП(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

