			СтруктураНоменклатура.Вставить("Code",Строка(Номенклатура.Код));
			СтруктураНоменклатура.Вставить("Ссылка",Номенклатура.Ссылка);

			ОбъектXDTO      = Фабрика.Создать(НоменклатураТип);

			ЗаполнитьЗначенияСвойств(ОбъектXDTO, СтруктураНоменклатура);

			РезультатОперации = Прокси.SetNomenclature(ОбъектXDTO, Узел.Идентификатор);
			
			Возврат РезультатОперации;
			
		КонецЕсли;	
				
		// Вид номенклатуры
