			СтруктураТовары.Вставить("QualityID",ПолучитьIDГрадацииКачества(СтрокаПеремещение.Номенклатура.Качество));
			
			Если Узел.ВыгружатьПартии Тогда
				
				//СтруктураТовары.Вставить(
				//	"ConsignmentID",
				//	Строка(ПеремещениеСсылка.СкладОтправитель.УникальныйИдентификатор()) + "_" + Строка(СтрокаПеремещение.Номенклатура.Код)
				//);
				
				СкладПолучательКод = ЗначенияРеквизитовСкладов[ПеремещениеСсылка.СкладОтправитель].Код;
				
				СтруктураТовары.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(СтрокаПеремещение.Номенклатура.Код)));
				
			Иначе
				СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
			КонецЕсли;
			
			СтруктураТовары.Вставить("Ссылка",СтрокаПеремещение);
			
			ТЧXDTO = Фабрика.Создать(СтрокаЗаказНаОтгрузкуТип);
			ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
					
			ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Добавить(ТЧXDTO);
		КонецЦикла;
		
		РезультатОперации = Прокси.SetShippingPlan(ОбъектXDTO_ЗаказНаОтгрузку, Узел.Идентификатор);
		
		Возврат РезультатОперации;
		
	Исключение
		
		ТекстСообщения = СтрШаблон("Не удалось выгрузить объект по причине:
			|- %1",  ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписатьОшибкуВЖурналРегистрации(
			ТекстСообщения,, ПеремещениеСсылка.Метаданные(), ПеремещениеСсылка.Ссылка);
		
		Возврат Ложь;
		
	КонецПопытки;
	
КонецФункции	

Функция ВыгрузитьКомплектацияНоменклатуры_ЗаказНаОтгрузку(КомплектацияСсылка, Узел)
	
	 // Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;
	
	// Организация
	ВыгрузитьОрганизацию(КомплектацияСсылка.Организация,Узел);
	
	// Контрагент
	КонтрагентСсылка = Справочники.Контрагенты.НайтиПоНаименованию("Списание товаров");
	ВыгрузитьПокупателя(КонтрагентСсылка,Узел);
	
	// Склад
	ВыгрузитьСклад(КомплектацияСсылка.Склад,Узел);
	
	// Заказ на отгрузку
	ЗаказНаОтгрузкуТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axShippingPlan");
	СтрокаЗаказНаОтгрузкуТип  = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axGoodsLine");
	
	// Доп. реквизиты. Поклажедатель (склад)
	ДополнительныеРеквизитыТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package", "axComplementaryElements");
	
	СтруктураДокумента = Новый Структура();
	СтруктураДокумента.Вставить("ID",Строка(КомплектацияСсылка.Ссылка.УникальныйИдентификатор()));
	СтруктураДокумента.Вставить("Date",КомплектацияСсылка.Дата);
	СтруктураДокумента.Вставить("Number","КН" + Прав(КомплектацияСсылка.Номер, СтрДлина(КомплектацияСсылка.Номер)-2));
	СтруктураДокумента.Вставить("ShipmentDirection","ОтгрузкаВПроизводство");
	СтруктураДокумента.Вставить("Priority","Обычная");
	СтруктураДокумента.Вставить("ExpectedDate",КомплектацияСсылка.Дата);
	СтруктураДокумента.Вставить("CounterpartyID",Строка(КонтрагентСсылка.УникальныйИдентификатор()));
	СтруктураДокумента.Вставить("OrganizationID",Строка(КомплектацияСсылка.Организация.УникальныйИдентификатор()));
	СтруктураДокумента.Вставить("Description",КомплектацияСсылка.Комментарий);
	СтруктураДокумента.Вставить("Ссылка",КомплектацияСсылка);
	СтруктураДокумента.Вставить("ContractDate",Дата("00010101"));
	СтруктураДокумента.Вставить("ContractNumber","");
	СтруктураДокумента.Вставить("IsMarked",КомплектацияСсылка.ПометкаУдаления);	
	
	ОбъектXDTO_ЗаказНаОтгрузку          = Фабрика.Создать(ЗаказНаОтгрузкуТип);
	ЗаполнитьЗначенияСвойств(ОбъектXDTO_ЗаказНаОтгрузку, СтруктураДокумента);
	
	// Поклажедатель / склад
	Если Узел.ВыгружатьПоклажедателя Тогда
		
		ОбъектXDTO_ДополнительныеРеквизиты = Фабрика.Создать(ДополнительныеРеквизитыТип);
		ОбъектXDTO_ДополнительныеРеквизиты.Attribute = "Поклажедатель";
		ОбъектXDTO_ДополнительныеРеквизиты.Value = СокрЛП(КомплектацияСсылка.Склад);
		
		ОбъектXDTO_ЗаказНаОтгрузку.ComplementaryElements.Добавить(ОбъектXDTO_ДополнительныеРеквизиты);
		
	КонецЕсли;	
	
	Для Каждого СтрокаКомплектации Из КомплектацияСсылка.Комплектующие Цикл
		
		// Номенклатура
		ВыгрузитьНоменклатуру(СтрокаКомплектации.Номенклатура,Узел);
		
		// Единица
		ВыгрузитьЕдиницу(СтрокаКомплектации.ЕдиницаИзмерения, Узел);
		
		// Качество
		ВыгрузитьКачество(СтрокаКомплектации.Номенклатура.Качество, Узел);
		
		// Партия
		ПартияСоздана = ВыгрузитьПартию(КомплектацияСсылка.Склад, СтрокаКомплектации.Номенклатура, Узел);
		
		// Строки документа "Заказ на отгрузку"
		СтруктураТовары = Новый Структура();
		СтруктураТовары.Вставить("NomenclatureID",Строка(СтрокаКомплектации.Номенклатура.УникальныйИдентификатор()));
		СтруктураТовары.Вставить("StorangeUnitID",Строка(СтрокаКомплектации.ЕдиницаИзмерения.УникальныйИдентификатор()));
		СтруктураТовары.Вставить("TaxRate","БезНДС");
		
		// Количество план = 0, если документ помечен на удаление
		КоличествоПлан = ?(КомплектацияСсылка.ПометкаУдаления, 0, СтрокаКомплектации.Количество);
		СтруктураТовары.Вставить("Quantity",КоличествоПлан);
		СтруктураТовары.Вставить("QuantityUnit",КоличествоПлан);
		СтруктураТовары.Вставить("LineNum", СтрокаКомплектации.ax_КодСтроки);
		СтруктураТовары.Вставить("QualityID", ПолучитьIDГрадацииКачества(СтрокаКомплектации.Номенклатура.Качество));
		
		Если Узел.ВыгружатьПартии Тогда
			СтруктураТовары.Вставить("ConsignmentID",Строка(КомплектацияСсылка.Склад.Код) + "_" + Строка(СтрокаКомплектации.Номенклатура.Код));
		Иначе
			СтруктураТовары.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
		КонецЕсли;
		
		СтруктураТовары.Вставить("Ссылка",КомплектацияСсылка);
		
		ТЧXDTO = Фабрика.Создать(СтрокаЗаказНаОтгрузкуТип);
		ЗаполнитьЗначенияСвойств(ТЧXDTO, СтруктураТовары);
				
		ОбъектXDTO_ЗаказНаОтгрузку.GoodsLine.Добавить(ТЧXDTO);
	КонецЦикла;
	
	РезультатОперации = Прокси.SetShippingPlan(ОбъектXDTO_ЗаказНаОтгрузку, Узел.Идентификатор);
	
	Возврат РезультатОперации;
	
КонецФункции 

Функция ВыгрузитьКомплектацияНоменклатуры_ВнутреннийЗаказ(КомплектацияСсылка, Узел)
	
