		СтруктураДокумента.Вставить("QualityID", ПолучитьIDГрадацииКачества(Перечисления.ГрадацииКачества.Новый));
		
		Если Узел.ВыгружатьПартии Тогда
			
			//СтруктураДокумента.Вставить("ConsignmentID",Строка(КомплектацияСсылка.Склад.Код) + "_" + Строка(КомплектацияСсылка.Номенклатура.Код));
			
			СкладПолучательКод = ЗначенияРеквизитовСкладов[КомплектацияСсылка.Склад].Код;
				
				СтруктураДокумента.Вставить("ConsignmentID", СтрШаблон("%1_%2", 
					СкладПолучательКод, Строка(КомплектацияСсылка.Номенклатура.Код)));
			
		Иначе
			СтруктураДокумента.Вставить("ConsignmentID","00000000-0000-0000-0000-000000000000");
		КонецЕсли;
		
		Количество = ?(КомплектацияСсылка.ПометкаУдаления, 0, КомплектацияСсылка.Количество);
		СтруктураДокумента.Вставить("Quantity",Количество);
		СтруктураДокумента.Вставить("KittingZone",Строка(КомплектацияСсылка.Склад.УникальныйИдентификатор()));
		//СтруктураДокумента.Вставить("SourceOrderID",Строка(КомплектацияСсылка.Заказ.Номер));
		СтруктураДокумента.Вставить("Description",КомплектацияСсылка.Комментарий);
		СтруктураДокумента.Вставить("IsMarked",КомплектацияСсылка.ПометкаУдаления);	
		
		ОбъектXDTO_ВнутреннийЗаказ          = Фабрика.Создать(ВнутреннийЗаказТип);
		ЗаполнитьЗначенияСвойств(ОбъектXDTO_ВнутреннийЗаказ, СтруктураДокумента);
		
