Функция _ВыгрузитьЕдиницу(Единица, Узел)
	
	//
	Если ТипЗнч(Единица) <> Тип("СправочникОбъект.УпаковкиЕдиницыИзмерения") Тогда
		Если НЕ ЗначениеЗаполнено(Единица) Тогда
			Возврат Истина;
		КонецЕсли;	
	КонецЕсли;
	
	// Инициализация
	Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
	
	Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
	Прокси.Пользователь = Узел.Пользователь;
	Прокси.Пароль       = Узел.Пароль;
	
	Фабрика = Прокси.ФабрикаXDTO;
	
	// Единица по классификатору (в УТ 11.05 ЕдиницаРодитель = Базовые единицы измерения)
	ЕдиницыКлассификаторТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package","axClassifierUnitsMesurement");
	
	СтруктураЕдиницаКлассификатор = Новый Структура();
	СтруктураЕдиницаКлассификатор.Вставить("ID",Строка(Единица.ЕдиницаИзмерения.УникальныйИдентификатор()));
	СтруктураЕдиницаКлассификатор.Вставить("ClassifierID",Строка("00000000-0000-0000-0000-000000000000"));
	СтруктураЕдиницаКлассификатор.Вставить("OwnerID",Строка("00000000-0000-0000-0000-000000000000"));
	СтруктураЕдиницаКлассификатор.Вставить("Name",Строка(Единица.ЕдиницаИзмерения.Наименование));
	СтруктураЕдиницаКлассификатор.Вставить("Code",Строка(Единица.ЕдиницаИзмерения.Код));
	СтруктураЕдиницаКлассификатор.Вставить("FullName",Строка(Единица.ЕдиницаИзмерения.Наименование));
	СтруктураЕдиницаКлассификатор.Вставить("Reduction",Строка(Единица.ЕдиницаИзмерения.МеждународноеСокращение));
	СтруктураЕдиницаКлассификатор.Вставить("weight",0);
	СтруктураЕдиницаКлассификатор.Вставить("volume",0);
	СтруктураЕдиницаКлассификатор.Вставить("coefficient",1);
	СтруктураЕдиницаКлассификатор.Вставить("height",0);
	СтруктураЕдиницаКлассификатор.Вставить("depth",0);
	СтруктураЕдиницаКлассификатор.Вставить("width",0);
	СтруктураЕдиницаКлассификатор.Вставить("barcode","");
	СтруктураЕдиницаКлассификатор.Вставить("UnitTypes",Ложь);
	СтруктураЕдиницаКлассификатор.Вставить("main",Истина);
	СтруктураЕдиницаКлассификатор.Вставить("Ссылка",Единица.ЕдиницаИзмерения);
	
	ТипОбъектXDTO = ЕдиницыКлассификаторТип;
	ОбъектXDTO          = Фабрика.Создать(ТипОбъектXDTO);
	ЗаполнитьЗначенияСвойств(ОбъектXDTO, СтруктураЕдиницаКлассификатор);
	РезультатОперации = Прокси.SetClassifierUnitsMesurement(ОбъектXDTO, Узел.Идентификатор);
	
	// Единица
	УпаковкиТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package","axStorangeUnit");
	
	СтруктураЕдиница = Новый Структура();
	СтруктураЕдиница.Вставить("ID",Строка(Единица.Ссылка.УникальныйИдентификатор()));
	СтруктураЕдиница.Вставить("ClassifierID",Строка(Единица.Ссылка.УникальныйИдентификатор()));
	СтруктураЕдиница.Вставить("OwnerID",Строка(Единица.Владелец.УникальныйИдентификатор()));
	СтруктураЕдиница.Вставить("Name",Строка(Единица.Наименование));
	СтруктураЕдиница.Вставить("Code",Строка(Единица.Код));
	СтруктураЕдиница.Вставить("FullName",Строка(Единица.Наименование));
	СтруктураЕдиница.Вставить("Reduction",Строка(Единица.МеждународноеСокращение));
	СтруктураЕдиница.Вставить("weight",Единица.Вес);
	СтруктураЕдиница.Вставить("volume",Единица.Объем);
	СтруктураЕдиница.Вставить("coefficient", 1);
	СтруктураЕдиница.Вставить("height",0);
	СтруктураЕдиница.Вставить("depth",0);
	СтруктураЕдиница.Вставить("width",0);
	СтруктураЕдиница.Вставить("barcode","");
	СтруктураЕдиница.Вставить("UnitTypes",Ложь);
	СтруктураЕдиница.Вставить("main",Истина);
	СтруктураЕдиница.Вставить("Ссылка",Единица.Ссылка);
	
	ТипОбъектXDTO          = УпаковкиТип;	
	ОбъектXDTO          = Фабрика.Создать(ТипОбъектXDTO);
	ЗаполнитьЗначенияСвойств(ОбъектXDTO, СтруктураЕдиница);
	
	РезультатОперации = Прокси.SetStorangeUnit(ОбъектXDTO, Узел.Идентификатор);
	
	Возврат РезультатОперации;
	
КонецФункции	

Функция ПолучитьУпаковкиНоменклатуры(НоменклатураСсылка)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", НоменклатураСсылка);
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.НаборУпаковок КАК НаборУпаковок
	|ПОМЕСТИТЬ втНоменклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УпаковкиЕдиницыИзмерения.Ссылка КАК Ссылка,
	|	УпаковкиЕдиницыИзмерения.Владелец КАК Владелец,
	|	УпаковкиЕдиницыИзмерения.Родитель КАК Родитель,
	|	УпаковкиЕдиницыИзмерения.Наименование КАК Наименование,
	|	УпаковкиЕдиницыИзмерения.Код КАК Код,
	|	УпаковкиЕдиницыИзмерения.НаименованиеПолное КАК НаименованиеПолное,
	|	УпаковкиЕдиницыИзмерения.МеждународноеСокращение КАК МеждународноеСокращение,
	|	УпаковкиЕдиницыИзмерения.Числитель КАК Числитель,
	|	УпаковкиЕдиницыИзмерения.Вес КАК Вес,
	|	УпаковкиЕдиницыИзмерения.Объем КАК Объем,
	|	УпаковкиЕдиницыИзмерения.Высота КАК Высота,
	|	УпаковкиЕдиницыИзмерения.Глубина КАК Глубина,
	|	УпаковкиЕдиницыИзмерения.Ширина КАК Ширина,
	|	УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ПОМЕСТИТЬ втУпаковкиЕдиницыИзмеренияИзменения
	|ИЗ
	|	втНоменклатура КАК втНоменклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
	|		ПО втНоменклатура.Ссылка = УпаковкиЕдиницыИзмерения.Владелец
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	УпаковкиЕдиницыИзмерения.Ссылка,
	|	втНоменклатура.Ссылка,
	|	УпаковкиЕдиницыИзмерения.Родитель,
	|	УпаковкиЕдиницыИзмерения.Наименование,
	|	УпаковкиЕдиницыИзмерения.Код,
	|	УпаковкиЕдиницыИзмерения.НаименованиеПолное,
	|	УпаковкиЕдиницыИзмерения.МеждународноеСокращение,
	|	УпаковкиЕдиницыИзмерения.Числитель,
	|	УпаковкиЕдиницыИзмерения.Вес,
	|	УпаковкиЕдиницыИзмерения.Объем,
	|	УпаковкиЕдиницыИзмерения.Высота,
	|	УпаковкиЕдиницыИзмерения.Глубина,
	|	УпаковкиЕдиницыИзмерения.Ширина,
	|	УпаковкиЕдиницыИзмерения.ЕдиницаИзмерения
	|ИЗ
	|	втНоменклатура КАК втНоменклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
	|		ПО втНоменклатура.НаборУпаковок = УпаковкиЕдиницыИзмерения.Владелец
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(втУпаковкиЕдиницыИзмеренияИзменения.Ссылка)) КАК ID,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(втУпаковкиЕдиницыИзмеренияИзменения.ЕдиницаИзмерения)) КАК ClassifierID,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(втУпаковкиЕдиницыИзмеренияИзменения.Владелец)) КАК OwnerID,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Наименование КАК Name,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Код КАК Code,
	|	втУпаковкиЕдиницыИзмеренияИзменения.НаименованиеПолное КАК FullName,
	|	втУпаковкиЕдиницыИзмеренияИзменения.МеждународноеСокращение КАК Reduction,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Вес КАК weight,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Объем КАК volume,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Числитель КАК coefficient,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Высота КАК height,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Глубина КАК depth,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Ширина КАК width,
	|	"""" КАК barcode,
	|	ЛОЖЬ КАК UnitTypes,
	|	ИСТИНА КАК main,
	|	втУпаковкиЕдиницыИзмеренияИзменения.Ссылка КАК Ссылка
	|ИЗ
	|	втУпаковкиЕдиницыИзмеренияИзменения КАК втУпаковкиЕдиницыИзмеренияИзменения";
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
		
КонецФункции

Функция ВыгрузитьНоменклатуру(Номенклатура, Узел)
	
	Попытка
		
		// Инициализация
		Определения = Новый WSОпределения(Узел.URL + "?wsdl", Узел.Пользователь, Узел.Пароль);
		Прокси = Новый WSПрокси(Определения, "http://www.axelot.ru/tms2_exchange/package", "axExchange", "axExchangeSoap");
		Прокси.Пользователь = Узел.Пользователь;
		Прокси.Пароль = Узел.Пароль;	
		Фабрика = Прокси.ФабрикаXDTO;

		Если Номенклатура.ЭтоГруппа Тогда
			
			// Группа номенклатуры
			СоздатьСтруктуруГруппНоменклатуры(Номенклатура, Узел);
			
			// Номенклатура
			НоменклатураТип = Фабрика.Тип("http://www.axelot.ru/tms2_exchange/package","axNomenclature");

			СтруктураНоменклатура = Новый Структура();
			СтруктураНоменклатура.Вставить("ID",Строка(Номенклатура.Ссылка.УникальныйИдентификатор()));
