Функция ПолучитьСтатусДокумента(ДокументСсылка, усСтатусДокумента) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ДокументОснование", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ax_СкладскойОрдер.усСтатусДокумента
	|ИЗ
	|	Документ.ax_СкладскойОрдер КАК ax_СкладскойОрдер
	|ГДЕ
	|	ax_СкладскойОрдер.ПометкаУдаления = ЛОЖЬ
	|	И ax_СкладскойОрдер.ДокументОснование = &ДокументОснование";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		СтатусWMS4 = усСтатусДокумента;
	Иначе
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			СтатусWMS4 = Выборка.усСтатусДокумента;
		Иначе
			СтатусWMS4 = усСтатусДокумента;
		КонецЕсли;	
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат СтатусWMS4;
	
КонецФункции

